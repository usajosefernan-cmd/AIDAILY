{
  "name": "ia-daily",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4322",
    "articles:slugs": "npx tsx scripts/ensure-article-slugs.js",
    "articles:related": "npx tsx scripts/build-related-articles.js",
    "news:sync": "npx tsx scripts/news-sync.js",
    "news:hot": "npx tsx scripts/hot-topics-cron.js",
    "news:validate": "npx tsx scripts/validate-news-data.js",
    "search:index": "node scripts/generate-search-index.cjs",
    "build:safe": "npm run articles:slugs && npm run articles:related && npm run news:validate && npm run search:index && npm run build",
    "deploy:staging": "node scripts/deploy-local.js",
    "deploy:prod": "node scripts/deploy-local.js --prod",
    "verify:local": "node scripts/verify-local.js",
    "verify:production": "node scripts/verify-production.js",
    "sync": "npm run news:sync && npm run build:safe && npm run deploy:prod && npm run verify:production"
  },
  "dependencies": {
    "@astrojs/db": "^0.21.3",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@types/xmldom": "^0.1.34",
    "astro": "^4.16.0",
    "chart.js": "^4.4.0",
    "date-fns": "^3.6.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rss": "^1.2.2",
    "sanitize-html": "^2.13.0",
    "trafilatura": "^0.2.0",
    "xlsx": "^0.18.5",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}