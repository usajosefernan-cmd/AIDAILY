{
  "name": "ia-daily",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "fetch": "node scripts/fetch-news.mjs",
    "sync": "npm run clean:sqlite && npm run news:sync && npm run news:validate && npm run deploy:safe",
    "clean:sqlite": "node scripts/clean-sqlite.js",
    "news:sync": "node scripts/news-sync.js",
    "news:hot": "node scripts/hot-topics-cron.js",
    "news:validate": "node scripts/validate-news-data.js",
    "build:safe": "npm run news:validate && npm run build",
    "deploy:safe": "bash deploy/deploy-safe.sh",
    "verify:production": "node scripts/verify-production.js"
  },
  "dependencies": {
    "@astrojs/db": "^0.21.3",
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@types/xmldom": "^0.1.34",
    "astro": "^4.16.0",
    "chart.js": "^4.4.0",
    "date-fns": "^3.6.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rss": "^1.2.2",
    "sanitize-html": "^2.13.0",
    "trafilatura": "^0.2.0",
    "xlsx": "^0.18.5",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}
