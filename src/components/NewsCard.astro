---
// NewsCard.astro - Tarjeta horizontal de alta densidad estilo The Athletic
import { getCategoryMeta, type CategoryKey } from '../lib/feeds.js';

interface Props {
  item: import('../lib/sources').NewsItem;
  index: number;
}

const { item, index } = Astro.props;
const publishedDate = new Date(item.publishedAt);
const timeStr = publishedDate.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });

const categoryKey = (item.tags?.[0] || 'general') as CategoryKey;
const meta = getCategoryMeta(categoryKey);
const badgeText = `${meta.icon} ${meta.title}`;
---

<article class="news-card row-card" role="listitem" data-article-id={item.id} tabindex="0" aria-label={`Abrir detalle de: ${item.title}`} style={`animation-delay: ${index * 25}ms`}>
  <div class="card-left">
    <header class="news-card-header">
      <div class="news-meta">
        <span class="news-source">{item.source}</span>
        <span class="meta-sep">•</span>
        <span class="news-cat-badge">{badgeText}</span>
        <span class="meta-sep">•</span>
        <time dateTime={item.publishedAt.toISOString()}>{timeStr}</time>
      </div>
      <h2 class="news-title">{item.title}</h2>
    </header>
    <div class="news-card-body">
      <p class="news-summary">{item.summary}</p>
      {item.tags && item.tags.length > 1 && (
        <div class="news-tags">
          {item.tags.slice(1, 4).map(tag => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
  
  {item.imageUrl && (
    <div class="card-right">
      <figure class="news-thumb-image">
        <img src={item.imageUrl} alt={item.imageAlt || item.title} loading="lazy" width="160" height="160" />
      </figure>
    </div>
  )}
</article>

<style>
  .news-card {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.06));
    background: transparent;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
    animation: slideUp 0.35s ease-out both;
  }

  .news-card:hover {
    transform: translateX(4px);
  }

  .card-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .card-right {
    flex-shrink: 0;
    margin-left: 1.25rem;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .news-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .news-source {
    color: var(--primary, #00d4aa);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-cat-badge {
    opacity: 0.85;
  }

  .meta-sep {
    opacity: 0.3;
  }

  .news-title {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text);
    margin: 0;
    transition: color 0.2s;
  }

  .news-card:hover .news-title {
    color: var(--primary);
  }

  .news-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .news-summary {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag {
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    text-transform: lowercase;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  @media (prefers-color-scheme: light) {
    .tag {
      background: rgba(0, 0, 0, 0.02);
      border: 1px solid rgba(0, 0, 0, 0.05);
    }
  }

  .news-thumb-image {
    margin: 0;
    width: 84px;
    height: 84px;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border, rgba(255,255,255,0.06));
    background: var(--surface);
  }

  .news-thumb-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .news-card:hover .news-thumb-image img {
    transform: scale(1.04);
  }

  /* Responsivo para móviles */
  @media (max-width: 640px) {
    .news-card {
      padding: 0.85rem 0;
    }
    .news-title {
      font-size: 0.92rem;
    }
    .news-summary {
      font-size: 0.78rem;
      -webkit-line-clamp: 2;
    }
    .news-thumb-image {
      width: 72px;
      height: 72px;
    }
    .card-right {
      margin-left: 0.85rem;
    }
  }
</style>

<script>
  // Click handler - opens modal via global event
  document.querySelectorAll('.news-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('a[target="_blank"]')) return;
      const articleId = (card as HTMLElement).dataset.articleId;
      if (articleId) {
        window.dispatchEvent(new CustomEvent('open-article-modal', {
          detail: { articleId }
        }));
      }
    });
    card.addEventListener('keydown', (e: any) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        (card as HTMLElement).click();
      }
    });
  });
</script>