---
// ArticleModal.astro - Modal Reader Mode premium con inyección dinámica del lado del cliente
---

<div
  class="article-modal"
  role="dialog"
  aria-modal="true"
  id="dynamic-article-modal"
  style="display: none;"
>
  <div class="article-modal-backdrop" id="modal-backdrop"></div>

  <div class="article-modal-panel">
    <header class="article-modal-header">
      <div class="flex-1 min-w-0">
        <div class="article-modal-meta">
          <span class="article-modal-source" id="modal-source"></span>
          <time class="article-modal-time" id="modal-time"></time>
          <span class="article-modal-category" id="modal-category"></span>
        </div>
        <h1 id="modal-title" class="article-modal-title"></h1>
      </div>
      <button
        class="article-modal-close"
        aria-label="Cerrar artículo"
        id="modal-close-btn"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </header>

    <div class="article-modal-body">
      <img
        id="modal-image"
        class="article-modal-image"
        style="display: none;"
        loading="eager"
        decoding="async"
      />

      <section class="article-modal-section" id="modal-section-why-matters" style="display: none;">
        <div class="article-modal-why-matters">
          <h2 class="article-modal-why-matters-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Por qué importa
          </h2>
          <p class="article-modal-why-matters-text" id="modal-why-matters-text"></p>
        </div>
      </section>

      <section class="article-modal-section" id="modal-section-summary" style="display: none;">
        <h2 class="article-modal-section-title">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Resumen en detalle
        </h2>
        <p class="article-modal-summary" id="modal-summary-text"></p>
      </section>

      <section class="article-modal-section" id="modal-section-keypoints" style="display: none;">
        <h2 class="article-modal-section-title">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          Claves de la noticia
        </h2>
        <ul class="article-modal-key-points" id="modal-keypoints-list" role="list">
        </ul>
      </section>

      <section class="article-modal-section" id="modal-section-multimedia" style="display: none;">
        <h2 class="article-modal-section-title">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Contenido multimedia
        </h2>
        <div class="article-modal-multimedia" id="modal-multimedia-list" role="list">
        </div>
      </section>

      <section class="article-modal-section" id="modal-section-fulltext" style="display: none;">
        <h2 class="article-modal-section-title">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          Texto original
        </h2>
        <div class="article-modal-fulltext" id="modal-fulltext-content"></div>
      </section>

      <footer class="article-modal-actions">
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
          id="modal-original-link"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Leer en fuente original
        </a>
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          id="modal-source-link"
        >
          Ver en fuente
        </a>
      </footer>
    </div>
  </div>
</div>

<style>
  /* Modal styles - Premium Reader Mode */
  .article-modal {
    position: fixed;
    inset: 0;
    z-index: 1000; /* Asegurar por encima de la barra de navegación */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    overflow-y: auto;
  }

  .article-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(10, 14, 20, 0.85);
    backdrop-filter: blur(8px);
    z-index: -1;
    animation: fadeIn 0.2s ease-out;
  }

  .article-modal-panel {
    background: #111827;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    max-width: 850px;
    width: 100%;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: slideUp 0.3s ease-out;
  }

  .article-modal-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #111827;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 1.25rem 1.75rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .article-modal-close {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    color: #94a3b8;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: all 0.2s;
  }
  .article-modal-close:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #00d4aa;
    border-color: #00d4aa;
  }

  .article-modal-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
  }
  .article-modal-source { font-weight: 700; color: #00d4aa; }
  .article-modal-time { color: #94a3b8; }
  .article-modal-category {
    padding: 0.25rem 0.75rem;
    background: rgba(0, 212, 170, 0.08);
    color: #00d4aa;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(0, 212, 170, 0.15);
  }
  .article-modal-title {
    font-family: 'Merriweather', Georgia, serif;
    font-size: clamp(1.2rem, 2.5vw, 1.85rem);
    font-weight: 900;
    line-height: 1.25;
    margin: 0;
    color: #fff;
  }

  .article-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.75rem;
  }

  .article-modal-image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 1.75rem;
  }

  .article-modal-section { margin-bottom: 2.25rem; }

  .article-modal-section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .article-modal-section-title svg { color: #00d4aa; flex-shrink: 0; }

  .article-modal-summary {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #94a3b8;
    background: rgba(255, 255, 255, 0.02);
    border-left: 4px solid #00d4aa;
    padding: 1.25rem;
    border-radius: 0 0.75rem 0.75rem 0;
    border: 1px solid rgba(255,255,255,0.05);
    border-left-width: 4px;
  }

  .article-modal-key-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .article-modal-key-points li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 0.75rem;
    transition: all 0.2s;
  }
  .article-modal-key-points li:hover {
    border-color: rgba(0, 212, 170, 0.3);
    background: rgba(0, 212, 170, 0.02);
  }
  .article-modal-key-point-icon {
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 212, 170, 0.1);
    color: #00d4aa;
    border-radius: 0.5rem;
  }
  .article-modal-key-point-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #94a3b8;
  }

  /* POR QUÉ IMPORTA - DISEÑO PREMIUM */
  .article-modal-why-matters {
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.08) 0%, rgba(11, 15, 25, 0) 100%);
    border: 1px solid rgba(0, 212, 170, 0.2);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 4px 20px -5px rgba(0, 212, 170, 0.05);
  }
  .article-modal-why-matters-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #00d4aa;
    margin: 0 0 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .article-modal-why-matters-title svg { color: #00d4aa; }
  .article-modal-why-matters-text {
    font-size: 0.975rem;
    line-height: 1.7;
    color: #fff;
    margin: 0;
    font-weight: 500;
  }

  .article-modal-multimedia {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .article-modal-media-item {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.05);
    background: rgba(255, 255, 255, 0.01);
  }
  .article-modal-media-item img,
  .article-modal-media-item video,
  .article-modal-media-item iframe {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .article-modal-media-caption {
    padding: 0.75rem;
    font-size: 0.8125rem;
    color: #94a3b8;
    text-align: center;
  }

  .article-modal-fulltext {
    font-size: 1rem;
    line-height: 1.75;
    color: #94a3b8;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-wrap: break-word;
  }
  .article-modal-fulltext p { margin-bottom: 1.25rem; }
  .article-modal-fulltext p:last-child { margin-bottom: 0; }

  .article-modal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 2rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    border: 1px solid transparent;
    cursor: pointer;
  }
  .btn-primary { background: #00d4aa; color: #0b0f19; }
  .btn-primary:hover { filter: brightness(1.1); }
  .btn-secondary { background: transparent; color: #94a3b8; border-color: rgba(255,255,255,0.08); }
  .btn-secondary:hover { border-color: #00d4aa; color: #fff; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 640px) {
    .article-modal { padding: 1rem; align-items: flex-start; }
    .article-modal-panel { max-height: 95vh; border-radius: 1.25rem; }
    .article-modal-body { padding: 1.25rem; }
    .article-modal-multimedia { grid-template-columns: 1fr; }
    .article-modal-actions { flex-direction: column; }
    .btn { width: 100%; justify-content: center; }
  }
</style>