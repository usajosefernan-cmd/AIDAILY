---
import PremiumPortal from '../../components/PremiumPortal.astro';

export async function getStaticPaths() {
  const categories = [
    'deportes', 'tecnologia', 'ciencia', 'medioambiente', 
    'internacional', 'nacional', 'economia', 'opinion', 
    'cultura', 'estilo', 'sociedad', 'gastronomia'
  ];
  return categories.map(cat => ({
    params: { category: cat },
    props: { categoryKey: cat }
  }));
}

const { categoryKey } = Astro.props;
---
<PremiumPortal initialCategory={categoryKey} />
