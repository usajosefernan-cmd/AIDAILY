---
import fs from 'fs';
import path from 'path';
import { DatabaseSync } from 'node:sqlite';

export async function getStaticPaths() {
  const dbPath = process.env.SQLITE_DB_PATH || path.resolve('data/aidaily.db');
  if (!fs.existsSync(dbPath)) return [];
  
  try {
    const db = new DatabaseSync(dbPath);
    const stmt = db.prepare("SELECT id, title FROM articles WHERE status = 'publicada' ORDER BY publishedAt DESC LIMIT 100");
    const rows = stmt.all() as any[];
    return rows.map(art => ({
      params: { id: art.id },
      props: { title: art.title }
    }));
  } catch (e) {
    console.error("Error al generar rutas en noticias/[id].astro:", e);
    return [];
  }
}

const { id } = Astro.params;
const { title } = Astro.props;

function getSlug(t) {
  if (!t) return '';
  let slug = t
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // Quitar acentos
    .replace(/[^a-z0-9]+/g, '-') // Cambiar no alfanuméricos por guiones
    .replace(/(^-|-$)+/g, ''); // Limpiar guiones iniciales y finales
  
  if (slug.length > 100) {
    slug = slug.substring(0, 100).replace(/-+$/, '');
  }
  return slug;
}

const slug = getSlug(title) || id;
const redirectUrl = `/pro/aidaily/noticias/${slug}/`;
return Astro.redirect(redirectUrl, 301);
---
