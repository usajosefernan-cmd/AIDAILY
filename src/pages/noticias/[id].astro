---
import fs from 'fs';
import path from 'path';
import { readFileSync, existsSync } from 'fs';

export async function getStaticPaths() {
  const cachePath = path.resolve('src/data/articles-light.json');
  if (!existsSync(cachePath)) return [];
  
  try {
    const cacheContent = readFileSync(cachePath, 'utf-8');
    const allArts = JSON.parse(cacheContent);
    if (Array.isArray(allArts)) {
      // Tomar los 100 más nuevos
      const sliced = allArts.slice(0, 100);
      return sliced.map(art => ({
        params: { id: art.id },
        props: { title: art.title }
      }));
    }
  } catch (e) {
    console.error("Error al generar rutas en noticias/[id].astro:", e);
  }
  return [];
}

const { id } = Astro.params;
const { title } = Astro.props;

function getSlug(t) {
  if (!t) return '';
  let slug = t
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // Quitar acentos
    .replace(/[^a-z0-9]+/g, '-') // Cambiar no alfanuméricos por guiones
    .replace(/(^-|-$)+/g, ''); // Limpiar guiones iniciales y finales
  
  if (slug.length > 100) {
    slug = slug.substring(0, 100).replace(/-+$/, '');
  }
  return slug;
}

const slug = getSlug(title) || id;
const redirectUrl = `/pro/aidaily/noticias/${slug}/`;
return Astro.redirect(redirectUrl, 301);
---
