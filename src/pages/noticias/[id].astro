---
import { readFileSync, existsSync } from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const cachePath = path.resolve('src/data/cache-news.json');
  if (!existsSync(cachePath)) return [];
  
  try {
    const cacheContent = readFileSync(cachePath, 'utf-8');
    const allArts = JSON.parse(cacheContent);
    if (Array.isArray(allArts)) {
      // Generar rutas estáticas de redirección 301 para TODOS los IDs históricos publicados
      return allArts.map(art => ({
        params: { id: art.id },
        props: { slug: art.slug, title: art.title }
      }));
    }
  } catch (e) {
    console.error("Error al generar rutas en noticias/[id].astro:", e);
  }
  return [];
}

const { id } = Astro.params;
const { slug, title } = Astro.props;

function getSlug(t) {
  if (!t) return '';
  let res = t
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // Quitar acentos
    .replace(/[^a-z0-9]+/g, '-') // Cambiar no alfanuméricos por guiones
    .replace(/(^-|-$)+/g, ''); // Limpiar guiones iniciales y finales
  
  if (res.length > 100) {
    res = res.substring(0, 100).replace(/-+$/, '');
  }
  return res;
}

const targetSlug = slug || getSlug(title) || id;
const redirectUrl = `/pro/aidaily/noticias/${targetSlug}/`;
return Astro.redirect(redirectUrl, 301);
---
