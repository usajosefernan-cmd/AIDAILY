---
import { readFileSync, existsSync } from 'fs';
import path from 'path';
import { normalizeSlug } from '../../lib/slug.js';

export async function getStaticPaths() {
  const cachePath = path.resolve('src/data/cache-news.json');
  if (!existsSync(cachePath)) return [];
  
  try {
    const cacheContent = readFileSync(cachePath, 'utf-8');
    const allArts = JSON.parse(cacheContent);
    if (Array.isArray(allArts)) {
      let sorted = [...allArts].sort((a, b) => new Date(b.publishedAt || b.published || 0).getTime() - new Date(a.publishedAt || a.published || 0).getTime());
      
      // Optimización local: solo 250 artículos para compilar rápido
      if (process.env.BUILD_ALL !== 'true') {
        sorted = sorted.slice(0, 250);
      }
      
      return sorted.map(art => ({
        params: { id: art.id },
        props: { slug: art.slug, title: art.title }
      }));
    }
  } catch (e) {
    console.error("Error al generar rutas en noticias/[id].astro:", e);
  }
  return [];
}

const { id } = Astro.params;
const { slug, title } = Astro.props;

const targetSlug = slug || normalizeSlug(title) || id;
const redirectUrl = `/pro/aidaily/noticias/${targetSlug}/`;
return Astro.redirect(redirectUrl, 301);
---
