---
import Layout from '../../layouts/Layout.astro';
import Portal from '../../components/Portal.jsx';
import fs from 'fs';
import path from 'path';
import { DatabaseSync } from 'node:sqlite';

export async function getStaticPaths() {
  const dbPath = process.env.SQLITE_DB_PATH || path.resolve('data/aidaily.db');
  if (!fs.existsSync(dbPath)) {
    console.warn("[Astro Build] No existe la base de datos en", dbPath);
    return [];
  }
  
  function getSlug(title) {
    if (!title) return '';
    let slug = title
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '') // Quitar acentos
      .replace(/[^a-z0-9]+/g, '-') // Cambiar no alfanuméricos por guiones
      .replace(/(^-|-$)+/g, ''); // Limpiar guiones iniciales y finales
    if (slug.length > 100) {
      slug = slug.substring(0, 100).replace(/-+$/, '');
    }
    return slug;
  }

  try {
    const db = new DatabaseSync(dbPath);
    const stmt = db.prepare("SELECT * FROM articles WHERE status = 'publicada'");
    const rows = stmt.all() as any[];
    return rows.map(art => {
      const slug = getSlug(art.title) || art.id;
      const norm = { category: art.category, subcategory: art.subcategory };
      const parsedArt = {
        ...art,
        tags: art.tags ? JSON.parse(art.tags) : [norm.category],
        tagsSecundarios: art.tagsSecundarios ? JSON.parse(art.tagsSecundarios) : [],
        keyPoints: art.keyPoints ? JSON.parse(art.keyPoints) : [],
        multimedia: art.multimedia ? JSON.parse(art.multimedia) : [],
        hashtags: art.hashtags ? JSON.parse(art.hashtags) : [],
        links: art.links ? JSON.parse(art.links) : [],
        interestingData: art.interestingData ? JSON.parse(art.interestingData) : []
      };
      return {
        params: { slug },
        props: { article: parsedArt }
      };
    });
  } catch (e) {
    console.error("Error al generar rutas en noticias/[slug].astro:", e);
    return [];
  }
}

const { article } = Astro.props;

if (!article) {
  return Astro.redirect('/pro/aidaily/');
}

const defaultImg = 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=800&auto=format&fit=crop&q=80';
const articleImg = article.imageUrl || (article.multimedia && article.multimedia[0]?.url) || defaultImg;
---

<Layout 
  title={`${article.title} — AIDAILY`} 
  description={article.summary || article.aiSummary}
  image={articleImg}
>
  <Portal 
    client:load 
    recentArticles={[article]} 
    totalArticlesCount={1}
    initialSelectedArticleId={article.id}
  />
</Layout>
