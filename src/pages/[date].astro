---
import Layout from '../layouts/Layout.astro';
import Portal from '../components/Portal.jsx';
import { getDatesToBuild } from '../lib/sources';
import { readFileSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const dates = getDatesToBuild().map(d => ({ params: { date: d } }));
  return dates;
}

const { date } = Astro.params;

let initialArticles = [];
try {
  const cachePath = join(process.cwd(), 'src/data/cache-news.json');
  const cacheData = JSON.parse(readFileSync(cachePath, 'utf-8'));
  if (Array.isArray(cacheData)) {
    initialArticles = cacheData.filter(art => {
      try {
        return new Date(art.publishedAt || art.published).toISOString().split('T')[0] === date;
      } catch (e) {
        return false;
      }
    });
    // Ordenar descendente
    initialArticles.sort((a, b) => {
      const timeA = new Date(a.publishedAt || a.published || 0).getTime();
      const timeB = new Date(b.publishedAt || b.published || 0).getTime();
      return timeB - timeA;
    });
  }
} catch (e) {
  console.error("Error al cargar cache en [date].astro", e);
}
---

<Layout title={`AIDAILY — Archivo ${date}`} description={`Archivo de noticias del día ${date}.`}>
  <Portal client:load recentArticles={initialArticles} totalArticlesCount={initialArticles.length} basePath={import.meta.env.BASE_URL} />
</Layout>
