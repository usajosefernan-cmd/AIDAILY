              </div>
            </div>
          `;
        }).join('');
      }

      menuList.innerHTML = highlightedHtml + mainHtml;
    }

    // Seleccionar trending topic desde menú móvil (cierra el drawer)
    window.selectTrendingTopicFromMenu = function(topicId, event) {
      if (event) event.stopPropagation();
      const menuDrawer = document.getElementById('menu-drawer');
      const menuOverlay = document.getElementById('menu-overlay');
      if (menuDrawer && menuOverlay) {
        menuDrawer.classList.remove('active');
        menuOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }
      selectTrendingTopic(topicId);
    };

    // Seleccionar categoría y subcategoría desde el menú móvil (cierra el drawer)
    window.selectCategoryAndSubcategoryFromMenu = function(category, subcat, event) {
      if (event) {
        event.stopPropagation();
      }
      const menuDrawer = document.getElementById('menu-drawer');
      const menuOverlay = document.getElementById('menu-overlay');
      if (menuDrawer && menuOverlay) {
        menuDrawer.classList.remove('active');
        menuOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }
      selectSubcategory(subcat, category);
    };

    // Seleccionar categoría completa
    window.selectCategory = function(category) {
      hideArticleDetail();
      activeCategory = category;
      activeSubcategory = null;
      activeHashtag = null;
      activeSource = null;
      currentPage = 1;
      
      updateURL();
      
      updateSectionTitle();

      renderCategories();
      renderMobileMenu();
      renderSubcategories();
      updateHashtagAnalyzer();
      renderFeed();
    };

    // Renderizar la barra secundaria de subcategorías editorial limpia y fija (mini-verticales)
    // Renderizar la barra secundaria de subcategorías editorial limpia y fija (mini-verticales) con breadcrumbs interactivos
    function renderSubcategories() {
      renderCategories();
    }

    // Seleccionar subcategoría y/o cambiar categoría padre
    window.selectSubcategory = function(subcat, parentCat, event) {
      if (event) {
        event.stopPropagation();
      }
      hideArticleDetail();
      if (parentCat) {
        activeCategory = parentCat;
      }
      activeSubcategory = subcat;
