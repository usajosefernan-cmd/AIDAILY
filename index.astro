    }

    // Función auxiliar para descomponer y limpiar subcategorías multinivel eliminando redundancias
    function getCleanSubcatPath(categoryKey, subcatStr) {
      if (!subcatStr) return ['General'];
      
      let rawParts = [];
      if (subcatStr.includes('/')) {
        rawParts = subcatStr.split('/');
      } else if (subcatStr.includes(' - ')) {
        rawParts = subcatStr.split(' - ');
      } else if (subcatStr.includes(' -> ')) {
        rawParts = subcatStr.split(' -> ');
      } else {
        // Buscar guión simple (ej. "Motor-F1") pero con cuidado de no romper palabras legítimas con guión
        // Si hay espacios a los lados del guión o es parte de un patrón deportivo
        if (subcatStr.includes('-')) {
          rawParts = subcatStr.split('-');
        } else {
          rawParts = [subcatStr];
        }
      }

      let parts = rawParts.map(p => p.trim()).filter(p => p.length > 0);

      // Filtrar subcategorías redundantes llamadas "VER TODO" o variaciones
      parts = parts.filter(p => {
        const lp = p.toLowerCase().trim();
        return lp !== 'ver todo' && lp !== 'vertodo' && !lp.includes('ver todo');
      });

      const catName = THEME_NAMES[categoryKey] || categoryKey;
      const normalizeText = (text) => text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();

      const normCatName = normalizeText(catName);
      const normCatKey = normalizeText(categoryKey);

      // Eliminar coincidencia con la categoría principal (ej. Deportes -> Deportes Fútbol)
      if (parts.length > 1) {
        const firstPartNorm = normalizeText(parts[0]);
        if (firstPartNorm === normCatName || firstPartNorm === normCatKey || firstPartNorm === 'nacional' || firstPartNorm === 'internacional' || firstPartNorm === 'deportes') {
          parts.shift();
        }
      }

      // Eliminar redundancias padre-hijo (ej. Fútbol -> Fútbol Femenino a Fútbol -> Femenino)
      for (let i = 1; i < parts.length; i++) {
        const parentNorm = normalizeText(parts[i - 1]);
        const currentNorm = normalizeText(parts[i]);
        if (currentNorm.startsWith(parentNorm)) {
          let childClean = parts[i].substring(parts[i - 1].length).trim();
          if (childClean.startsWith('-') || childClean.startsWith('—') || childClean.startsWith(':')) {
            childClean = childClean.substring(1).trim();
          }
          if (childClean) {
            parts[i] = childClean;
          }
        }
      }

      parts = parts.map(p => p.trim()).filter(p => p.length > 0);
      return parts.length > 0 ? parts : ['General'];
    }

    // Obtener ruta interna normalizada de la subcategoría para comparaciones y filtros
    function getNormalizedSubcatPath(categoryKey, subcatStr) {
      const parts = getCleanSubcatPath(categoryKey, subcatStr);
      return parts.map(p => {
        const lp = p.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
        if (lp.includes('inteligencia artificial')) return 'ia';
        if (lp.includes('llms') || lp.includes('modelos')) return 'llms';
        if (lp.includes('desarrollo') || lp.includes('apis')) return 'desarrollo';
        if (lp === 'la liga' || lp === 'laliga') return 'laliga';
        if (lp === 'copa' || lp === 'copa & rfef' || lp === 'rfef') return 'copa';
        if (lp === 'champions league' || lp === 'champions') return 'champions';
        if (lp === 'formula 1' || lp === 'f1') return 'formula 1';
        if (lp === 'motogp' || lp === 'moto gp') return 'motogp';
        if (lp === 'ue' || lp === 'union europea') return 'ue';
        if (lp === 'latam' || lp === 'latinoamerica') return 'latam';
        return lp;
      }).join('/');
    }

    // Obtener ruta legible unida por " › " para breadcrumbs del menú/modal
    function getReadableSubcatPath(subcatPathStr) {
      if (!subcatPathStr) return '';
      return subcatPathStr.split('/').map(part => {
        const cleanPart = part.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        return SUBCATEGORY_NAMES[cleanPart] || part.charAt(0).toUpperCase() + part.slice(1);
      }).join(' › ');
    }

    // Obtener ruta legible para mostrar en las tarjetas de noticias
    function getReadableSubcatForCard(categoryKey, subcatStr) {
      if (!subcatStr) return '';
      const parts = getCleanSubcatPath(categoryKey, subcatStr);
      return parts.map(part => {
        const cleanPart = part.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        return SUBCATEGORY_NAMES[cleanPart] || part;
      }).join(' › ');
    }

    // Función auxiliar para insertar dinámicamente rutas multinivel en el árbol
    function insertIntoCategoryTree(category, subcatPathStr) {
      if (!category || !subcatPathStr) return;
      const catKey = category.toLowerCase().trim();
      if (!CATEGORY_TREE[catKey]) {
        const name = THEME_NAMES[catKey] || (catKey.charAt(0).toUpperCase() + catKey.slice(1));
        CATEGORY_TREE[catKey] = { name: name, children: {} };
      }
      
      if (!CATEGORY_TREE[catKey].children) {
        CATEGORY_TREE[catKey].children = {};
      }

      const parts = getCleanSubcatPath(catKey, subcatPathStr);
      let currentLevel = CATEGORY_TREE[catKey].children;
      
      parts.forEach((part, index) => {
        const partKey = part.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        if (!partKey) return;
        
        if (!currentLevel[partKey]) {
          let readableName = SUBCATEGORY_NAMES[partKey] || part;
          if (partKey === '1') readableName = '1ª División';
          if (partKey === '2') readableName = '2ª División';
          
          currentLevel[partKey] = {
            name: readableName
          };
        }
        
        if (index < parts.length - 1) {
          if (!currentLevel[partKey].children) {
            currentLevel[partKey].children = {};
          }
          currentLevel = currentLevel[partKey].children;
        }
      });
    }

