---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Cargar artículos del caché local para inyectarlos en la página
let recentArticles = [];
try {
  const cachePath = path.resolve('src/data/cache-news.json');
  if (fs.existsSync(cachePath)) {
    const cacheContent = fs.readFileSync(cachePath, 'utf-8');
    const allArts = JSON.parse(cacheContent);
    if (Array.isArray(allArts)) {
      // Ordenar por fecha descendente (más nuevos primero) para inyectar noticias actuales
      allArts.sort((a, b) => new Date(b.publishedAt) - new Date(a.publishedAt));
      // Tomar los 200 artículos más nuevos
      recentArticles = allArts.slice(0, 200);
    }
  }
} catch (e) {
  console.error("Error cargando caché local en index.astro:", e);
}
