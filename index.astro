    // Renderizar menú hamburguesa vertical con portales y categorías colapsables en móvil
    function renderMobileMenu() {
      const menuList = document.getElementById('menu-drawer-list');
      if (!menuList) return;

      const portalKeys = ['breaking', 'actualidad', 'tecnologia-ciencia', 'economia-negocios', 'estilo-vida', 'deportes'];

      let mainHtml = portalKeys.map(portal => {
        const portalName = PORTAL_NAMES[portal] || portal;
        const isActivePortal = activeCategory === portal || (PORTAL_MAPPING[portal] && PORTAL_MAPPING[portal].includes(activeCategory));

        if (portal === 'breaking') {
          const isActive = activeCategory === 'breaking';
          return `
            <div class="drawer-category-group">
              <div class="drawer-item ${isActive ? 'active' : ''}" onclick="selectCategoryAndSubcategoryFromMenu('breaking', null, event)" style="color: #f87171;">
