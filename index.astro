    window.openLightbox = function(url, caption, articleId) {
      if (!lightboxOverlay || !lightboxImg || !lightboxCaption) return;

      currentLightboxGallery = [];
      currentLightboxIndex = 0;

      // Buscar el artículo en memoria para extraer todas sus imágenes de cobertura
      const art = allArticles.find(a => a.id === articleId);
      if (art) {
        // 1. Agregar portada si tiene y es válida
        const featuredImg = art.imageUrl;
        if (featuredImg && !featuredImg.includes('placeholder') && !featuredImg.includes('logo')) {
          currentLightboxGallery.push({
            url: featuredImg,
            caption: art.title || 'Portada de la noticia'
          });
        }
        
        // 2. Agregar el resto de imágenes multimedia seleccionadas por la IA
        if (Array.isArray(art.multimedia)) {
          art.multimedia.forEach(m => {
            if (m.type === 'image' && m.url) {
              // Evitar duplicados de URL
              if (!currentLightboxGallery.some(item => item.url === m.url)) {
                currentLightboxGallery.push({
                  url: m.url,
                  caption: m.caption || m.alt || art.title || 'Imagen relacionada'
                });
              }
            }
          });
        }
      }

      // Fallback si no encontramos el artículo o no tiene galería: cargamos la imagen cliqueada
      if (currentLightboxGallery.length === 0) {
        currentLightboxGallery.push({ url, caption: caption || '' });
      }

      // Buscar el índice inicial de la imagen pulsada
      const foundIdx = currentLightboxGallery.findIndex(item => item.url === url);
      currentLightboxIndex = foundIdx >= 0 ? foundIdx : 0;

      // Dibujar imagen y contador
      updateLightboxContent();

      lightboxOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';

      // Iniciar gestos swipe
      setupLightboxTouchEvents();
