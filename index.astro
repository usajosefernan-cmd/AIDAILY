    // Parsear la búsqueda para soportar operadores Y/AND, O/OR, NO/NOT/negativos (-)
    function parseSearchQuery(query) {
      const terms = query.split(/\s+/).filter(t => t.length > 0);
      const positive = [];
      const negative = [];
      const orGroups = [];
      
      let i = 0;
      while (i < terms.length) {
        const term = terms[i];
        
        // Detectar negativo -term
        if (term.startsWith('-') && term.length > 1) {
          const clean = term.substring(1).toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          if (clean) negative.push(clean);
          i++;
          continue;
        }
        
        // Detectar NOT / NO
        if ((term.toUpperCase() === 'NOT' || term.toUpperCase() === 'NO') && i + 1 < terms.length) {
          const nextTerm = terms[i + 1].toLowerCase().replace(/^[-+]/, '').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          if (nextTerm) negative.push(nextTerm);
          i += 2;
          continue;
        }
        
        // Detectar OR / O / |
        if (i + 1 < terms.length && (terms[i + 1].toUpperCase() === 'OR' || terms[i + 1].toUpperCase() === 'O' || terms[i + 1] === '|') && i + 2 < terms.length) {
          const left = term.toLowerCase().replace(/^[-+]/, '').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const right = terms[i + 2].toLowerCase().replace(/^[-+]/, '').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          if (left && right) orGroups.push([left, right]);
          i += 3;
          continue;
        }
        
        // Por defecto positivo (AND)
        const clean = term.toLowerCase().replace(/^[-+]/, '').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        if (clean && clean !== 'and' && clean !== 'y' && clean !== 'or' && clean !== 'o' && clean !== 'not' && clean !== 'no' && clean !== '|') {
          positive.push(clean);
        }
        i++;
      }
      
      return { positive, negative, orGroups };
    }

    // Helper para obtener artículos filtrados
    function getFilteredArticles() {
      const filtered = allArticles.filter(art => {
        // Exclusión incondicional de noticias en inglés remanentes
        const hasEnglishWords = /\b(the|and|of|with|from|this|that|about|would|their|there|which)\b/i;
        const isEnglish = hasEnglishWords.test(art.title);
        if (isEnglish) {
          return false;
        }

        // Filtro por fecha del archivo (solo si la categoría activa es 'date')
        if (activeCategory === 'date' && activeDateParam) {
          try {
            const artDateStr = new Date(art.publishedAt).toISOString().split('T')[0];
            if (artDateStr !== activeDateParam) {
              return false;
            }
          } catch (e) {
            return false;
          }
        }

        // Filtro categoría (se ignora si hay una búsqueda activa para buscar de forma global)
        if (activeCategory !== 'breaking' && !searchQuery) {
          const artCat = normalizeText(art.category);
          const activeCatNorm = normalizeText(activeCategory);
          if (PORTAL_MAPPING[activeCatNorm]) {
            // Es un portal completo
            if (!PORTAL_MAPPING[activeCatNorm].includes(artCat)) {
              return false;
            }
          } else {
            // Es una categoría específica
            if (artCat !== activeCatNorm) {
              return false;
            }
          }
        }
        // Filtro subcategoría (normalizado y flexible de rutas jerárquicas)
        if (activeSubcategory) {
          const artPath = getNormalizedSubcatPath(art.category, art.subcategory);
          const activePath = activeSubcategory.toLowerCase();
          if (!artPath || (!artPath.includes(activePath) && !activePath.includes(artPath))) {
            return false;
          }
        }
        // Filtro hashtag
        if (activeHashtag) {
          const cleanTags = getCleanHashtags(art.hashtags).map(t => normalizeText(t));
          if (!cleanTags.includes(normalizeText(activeHashtag))) {
            return false;
          }
        }
        // Filtro fuente
        if (activeSource) {
          if (normalizeText(art.source) !== normalizeText(activeSource)) {
            return false;
          }
        }
        // Filtro buscador y Temas Calientes Dinámicos
        if (window.activeTrendingTopic) {
          const topic = window.activeTrendingTopic;
          const keywords = topic.keywords || [topic.title];
          
          // Verificar si el artículo coincide con el tema principal (al menos una keyword coincide)
          const matchesTopic = keywords.some(kw => {
            const q = kw.toLowerCase().trim();
            const titleText = typeof art.title === 'string' ? art.title : (art.title ? String(art.title) : '');
            const summaryText = typeof art.summary === 'string' ? art.summary : (art.summary ? String(art.summary) : '');
            const subText = typeof art.subcategory === 'string' ? art.subcategory : (art.subcategory ? String(art.subcategory) : '');
            
            const matchTitle = titleText.toLowerCase().includes(q);
            const matchSummary = summaryText.toLowerCase().includes(q);
            const matchSub = subText.toLowerCase().includes(q);
            const cleanTags = getCleanHashtags(art.hashtags);
            const matchHash = cleanTags.some(h => typeof h === 'string' ? h.toLowerCase().includes(q) : false);
            return matchTitle || matchSummary || matchSub || matchHash;
          });

          if (!matchesTopic) {
            return false;
          }

          // Si hay una sub-búsqueda activa (etapas, subtemas específicos)
          if (searchQuery && searchQuery !== topic.title.toLowerCase().trim() && !keywords.includes(searchQuery)) {
            const titleText = typeof art.title === 'string' ? art.title : (art.title ? String(art.title) : '');
            const summaryText = typeof art.summary === 'string' ? art.summary : (art.summary ? String(art.summary) : '');
            const subText = typeof art.subcategory === 'string' ? art.subcategory : (art.subcategory ? String(art.subcategory) : '');
            
            const matchTitle = titleText.toLowerCase().includes(searchQuery);
            const matchSummary = summaryText.toLowerCase().includes(searchQuery);
            const matchSub = subText.toLowerCase().includes(searchQuery);
            const cleanTags = getCleanHashtags(art.hashtags);
            const matchHash = cleanTags.some(h => typeof h === 'string' ? h.toLowerCase().includes(searchQuery) : false);
            if (!matchTitle && !matchSummary && !matchSub && !matchHash) {
              return false;
            }
          }
        } else if (searchQuery) {
          // Búsqueda inteligente con operadores AND / OR / NOT
          const parsed = parseSearchQuery(searchQuery);
          
          const titleText = (typeof art.title === 'string' ? art.title : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const summaryText = (typeof art.summary === 'string' ? art.summary : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const subText = (typeof art.subcategory === 'string' ? art.subcategory : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const catText = (typeof art.category === 'string' ? art.category : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const srcText = (typeof art.source === 'string' ? art.source : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const tagsText = (Array.isArray(art.tags) ? art.tags.filter(t => typeof t === 'string').join(' ') : '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const cleanTags = getCleanHashtags(art.hashtags);
          const hashText = cleanTags.filter(h => typeof h === 'string').join(' ').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const allText = titleText + ' ' + summaryText + ' ' + subText + ' ' + catText + ' ' + srcText + ' ' + tagsText + ' ' + hashText;
          
          // 1. Negativos (ninguno debe estar)
          if (parsed.negative.length > 0) {
            const matchesNegative = parsed.negative.some(term => allText.includes(term));
            if (matchesNegative) return false;
          }
          
          // 2. Positivos (todos deben estar)
          if (parsed.positive.length > 0) {
            const matchesPositive = parsed.positive.every(term => allText.includes(term));
            if (!matchesPositive) return false;
          }
          
          // 3. Grupos OR (se debe cumplir cada grupo OR individual)
          if (parsed.orGroups.length > 0) {
            const matchesOr = parsed.orGroups.every(group => {
              return group.some(term => allText.includes(term));
            });
            if (!matchesOr) return false;
          }
        }
        return true;
      });
      
      return sortArticlesPersonalized(filtered);
    }

    // Helper para renderizar un lote de artículos en HTML
    function renderArticlesBatchHtml(articles) {
      return articles.map(art => {
        const categoryKey = (art.category || 'general').toLowerCase();
        const themeName = THEME_NAMES[categoryKey] || 'General';
        const subReadable = getReadableSubcatForCard(categoryKey, art.subcategory);
        const sub = subReadable ? ` • ${subReadable.toUpperCase()}` : '';
        const dateStr = formatRelativeDate(art.publishedAt);
        const cleanTags = getCleanHashtags(art.hashtags);
        const imgUrl = getArticleImageUrl(art);
        
        // Determinar si es de última hora (menor a 4 horas o menor a 1 hora)
        const diffMs = Date.now() - new Date(art.publishedAt).getTime();
        const diffMin = Math.round(diffMs / 60000);
        const diffHours = Math.round(diffMs / 3600000);
        
        let breakingBadge = '';
        if (diffMs < 1 * 3600 * 1000) {
          const mins = diffMin <= 0 ? 1 : diffMin;
          breakingBadge = `<span class="card-breaking-badge card-lasthour-badge"><span class="pulsing-dot pulsing-dot-fast"></span>HACE ${mins}m</span>`;
        } else if (diffMs < 4 * 3600 * 1000) {
          breakingBadge = `<span class="card-breaking-badge"><span class="pulsing-dot"></span>HACE ${diffHours}h</span>`;
        }
        
        return `
          <div class="row-card" onclick="openArticle('${art.id}')">
            <div class="row-card-content">
              <div class="card-meta" style="margin-bottom: 4px;">
                ${breakingBadge}
                <span style="font-weight: 800; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.3px;">${themeName.toUpperCase()}${sub.toUpperCase()}</span>
                <span>• RSS: ${dateStr}</span>
              </div>
              <h3 class="row-card-title">${art.title}</h3>
              <p class="row-card-summary">${art.summary}</p>
              ${cleanTags.length > 0 ? `
                <div class="card-tags" style="margin-top: 4px;">
                  ${cleanTags.slice(0, 2).map(h => `<span class="card-tag clickable-tag" style="color: var(--accent-cyan); font-weight: 500; font-size: 0.64rem; padding: 2px 8px;" onclick="event.stopPropagation(); selectHashtagFromCard('${h}')">${h}</span>`).join('')}
                </div>
              ` : ''}
            </div>
            <div class="row-card-img-wrapper">
              <img class="row-card-img" src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}" loading="lazy">
            </div>
          </div>
        `;
      }).join('');
    }

    // Renderizar Feed de Noticias
    // Renderizar Feed de Noticias v2.1 (Paginación Clásica)
    // Renderizar Sidebar Contextual Dinámico (Otras Noticias, Temas Calientes de la sección, Opinión)
    // Renderizar Sidebar Contextual Dinámico con Temas de Actualidad (tarjetas premium estilo destacados), Tags Calientes e Hilos de Opinión
    function renderSidebarContextual() {
      const sidebarContainer = document.getElementById('nyt-sidebar-container');
      if (!sidebarContainer) return;

      const isHomepage = (activeCategory === 'breaking' && !searchQuery && !activeHashtag && !activeSubcategory && !activeSource);
      
      // Obtener todos los temas calientes
      const allTopics = Object.values(window.trendingTopics || {})
        .filter(t => t && t.id && t.id !== 'updatedAt' && t.id !== 'windowHours');

      // Temas importantes (los de la cabecera)
      const highlightedIds = window.highlightedTopics || [];
      const primaryTopics = allTopics.filter(t => {
        const isManualHighlighted = highlightedIds.includes(t.id);
        const isCriticalType = t.type === 'breaking' || t.type === 'event';
        const isHighlyPopular = (t.popularity >= 0.8) || (t.popularity >= 80);
        return isManualHighlighted || isCriticalType || isHighlyPopular;
      });

      // Temas de actualidad secundarios (los del sidebar)
      const secondaryTopics = allTopics.filter(t => !primaryTopics.some(pt => pt.id === t.id));

      // Helper para buscar el artículo más representativo del tema
      function getArticleForTopic(topic) {
        const keywords = topic.keywords || [topic.title];
        return allArticles.find(art => {
          return keywords.some(kw => {
            const q = kw.toLowerCase().trim();
            const titleText = (art.title || '').toLowerCase();
            const summaryText = (art.summary || '').toLowerCase();
            const cleanTags = getCleanHashtags(art.hashtags).map(h => h.toLowerCase());
            return titleText.includes(q) || summaryText.includes(q) || cleanTags.some(h => h.includes(q));
          });
        });
      }

      // A) TEMAS DE ACTUALIDAD (Diseño premium tipo miniaturas de arriba)
      let sideTopicsHtml = '';
      let matchedCount = 0;

      for (const t of secondaryTopics) {
        if (matchedCount >= 4) break; // Límite de 4 tarjetas visuales en el sidebar
        const art = getArticleForTopic(t);
        if (art) {
          matchedCount++;
          const imgUrl = getArticleImageUrl(art);
          const timeStr = formatRelativeDate(art.publishedAt);
          
          sideTopicsHtml += `
            <div class="sidebar-item-premium-card" onclick="openArticle('${art.id}')" style="position: relative; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.015); margin-bottom: 14px; cursor: pointer; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 20px rgba(0,0,0,0.15);" onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='rgba(6,182,212,0.25)'; this.style.background='rgba(255,255,255,0.03)';" onmouseout="this.style.transform='none'; this.style.borderColor='rgba(255,255,255,0.06)'; this.style.background='rgba(255,255,255,0.015)';">
              <div style="width: 100%; height: 95px; position: relative; overflow: hidden; background: #000;">
                <img src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" loading="lazy">
                <!-- Badge de Categoría/Tema superpuesto de forma absoluta (estilo destacados de arriba) -->
                <div style="position: absolute; top: 8px; left: 8px; background: rgba(9, 9, 16, 0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.1); padding: 3px 8px; font-size: 0.56rem; font-weight: 800; border-radius: 6px; color: #fff; text-transform: uppercase; letter-spacing: 0.5px; display: inline-flex; align-items: center; gap: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.3);">
                  <span class="pulsing-dot pulsing-dot-fast" style="width: 4px; height: 4px; background: #ef4444; display: inline-block; border-radius: 50%;"></span>
                  ${t.title}
                </div>
              </div>
              <div style="padding: 10px 12px;">
                <h5 style="margin: 0; font-size: 0.74rem; font-weight: 700; line-height: 1.35; color: #f3f4f6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; font-family: var(--font-body);">${art.title}</h5>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px; font-size: 0.58rem; color: var(--text-muted); font-weight: 600;">
                  <span style="color: var(--accent-cyan);">${(art.category || 'general').toUpperCase()}</span>
                  <span>${timeStr}</span>
                </div>
              </div>
            </div>
          `;
        }
      }

      if (!sideTopicsHtml) {
        sideTopicsHtml = `<div style="font-size: 0.7rem; color: var(--text-muted); padding: 8px 0;">No hay temas de actualidad alternativos hoy.</div>`;
      }

      // B) TEMAS CALIENTES (Tags del feed)
      const allTags = {};
      const targetArticlesForTags = isHomepage ? allArticles : allArticles.filter(art => {
        const portalCats = PORTAL_MAPPING[activeCategory] || [activeCategory];
        return portalCats.map(normalizeText).includes(normalizeText(art.category));
      });

      targetArticlesForTags.forEach(art => {
        const tags = getCleanHashtags(art.hashtags);
        tags.forEach(t => {
          const clean = t.trim();
          if (clean) allTags[clean] = (allTags[clean] || 0) + 1;
        });
      });
      
      const sortedTags = Object.entries(allTags)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 5);
      
      let hashtagsHtml = '';
      if (sortedTags.length > 0) {
        hashtagsHtml = sortedTags.map(([tag, count], idx) => {
          const cleanTag = tag.replace('#', '');
          return `
            <div class="sidebar-item" onclick="selectHashtag('${tag}')" style="padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.03); cursor: pointer;">
              <h5 class="sidebar-item-title" style="font-family: var(--font-body); font-size: 0.74rem; font-weight: 600; text-transform: capitalize; color: #e5e7eb; margin: 0;">
                ${idx + 1}. #${cleanTag}
              </h5>
              <div class="sidebar-item-meta" style="font-size: 0.58rem; color: var(--text-muted); margin-top: 1px;">${count} reportes asociados</div>
            </div>
          `;
        }).join('');
      } else {
        hashtagsHtml = `<div style="font-size: 0.7rem; color: var(--text-muted); padding: 4px 0;">No hay tendencias en esta sección.</div>`;
