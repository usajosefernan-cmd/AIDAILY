          if (entry.isIntersecting && !isLoadingNextArticle) {
            if (infiniteNextIndex < infiniteArticlesQueue.length) {
              loadNextInfiniteArticleBatch();
            }
          }
        });
      }, {
        rootMargin: "350px" // Dispara anticipadamente para excelente fluidez
      });

      detailTriggerObserver.observe(trigger);
    }


