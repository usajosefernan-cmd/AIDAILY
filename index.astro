                VER PORTAL COMPLETO
              </div>
              ${portalCats.map(cat => {
                const catName = THEME_NAMES[cat] || cat;
                const isCatActive = activeCategory === cat;
                const subTree = CATEGORY_TREE[cat]?.children || {};
                const hasSubTree = Object.keys(subTree).length > 0;
                
                if (hasSubTree) {
                  const isSubExpanded = isCatActive;
                  return `
                    <div class="drawer-submenu-group" style="padding-left: 12px; margin-top: 4px;">
                      <div class="drawer-sub-item-header" onclick="toggleMobileCategory(event, '${cat}')">
                        <span onclick="selectCategoryAndSubcategoryFromMenu('${cat}', null, event)" style="${isCatActive ? 'color: var(--accent-cyan); font-weight: 700;' : ''}">${catName.toUpperCase()}</span>
                        <span class="drawer-submenu-arrow ${isSubExpanded ? 'expanded' : ''}">▼</span>
                      </div>
                      <div class="drawer-sub-submenu-list ${isSubExpanded ? 'active' : ''}" id="drawer-cat-sub-${cat}" style="padding-left: 12px;">
                        ${Object.entries(subTree).map(([subKey, subNode]) => {
                          const isSubActive = activeCategory === cat && (activeSubcategory === subKey || activeSubcategory?.startsWith(subKey + '/'));
                          const subSubTree = subNode.children || {};
                          const hasSubSubTree = Object.keys(subSubTree).length > 0;
                          
                          if (hasSubSubTree) {
                            const isSubSubExpanded = isSubActive;
                            return `
                              <div class="drawer-submenu-group" style="padding-left: 8px; margin-top: 4px;">
                                <div class="drawer-sub-item-header" onclick="toggleMobileSubcategory(event, '${cat}', '${subKey}')" style="padding: 6px 8px; font-size: 0.68rem;">
                                  <span onclick="selectCategoryAndSubcategoryFromMenu('${cat}', '${subKey}', event)" style="${isSubActive ? 'color: var(--accent-cyan); font-weight: 700;' : ''}">${subNode.name.toUpperCase()}</span>
                                  <span class="drawer-sub-submenu-arrow ${isSubSubExpanded ? 'expanded' : ''}">▼</span>
                                </div>
                                <div class="drawer-sub-sub-submenu-list ${isSubSubExpanded ? 'active' : ''}" id="drawer-subcat-sub-${cat}-${subKey}" style="padding-left: 12px;">
                                  ${Object.entries(subSubTree).map(([subSubKey, subSubNode]) => {
                                    const fullPath = `${subKey}/${subSubKey}`;
                                    const isSubSubActive = activeCategory === cat && activeSubcategory === fullPath;
                                    return `
                                      <div class="drawer-sub-item ${isSubSubActive ? 'active' : ''}" onclick="selectCategoryAndSubcategoryFromMenu('${cat}', '${fullPath}', event)" style="font-size: 0.65rem; padding: 6px 8px;">
