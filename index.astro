    // Soporte para gestos Swipe en móviles
    let touchStartX = 0;
    let touchEndX = 0;

    function setupLightboxTouchEvents() {
      if (!lightboxOverlay) return;
      lightboxOverlay.removeEventListener('touchstart', handleTouchStart);
      lightboxOverlay.removeEventListener('touchend', handleTouchEnd);
      
      lightboxOverlay.addEventListener('touchstart', handleTouchStart, { passive: true });
      lightboxOverlay.addEventListener('touchend', handleTouchEnd, { passive: true });
    }

    // Soporte de navegación por teclado (Esc y flechas)
    document.addEventListener('keydown', (e) => {
      if (!lightboxOverlay || !lightboxOverlay.classList.contains('active')) return;
      if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') {
        lightboxNext();
      } else if (e.key === 'ArrowLeft' || e.key === 'a' || e.key === 'A') {
        lightboxPrev();
      } else if (e.key === 'Escape') {
        closeLightbox();
      }
    });

    function handleTouchStart(e) {
      touchStartX = e.changedTouches[0].screenX;
    }

    function handleTouchEnd(e) {
      touchEndX = e.changedTouches[0].screenX;
      const swipeDistance = touchEndX - touchStartX;
      if (Math.abs(swipeDistance) > 50) {
        if (swipeDistance < 0) {
          lightboxNext();
        } else {
          lightboxPrev();
        }
      }
    }

