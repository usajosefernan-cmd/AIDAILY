    // Renderizar footer dinámico agrupado por los 5 Portales Principales
    function renderFooter() {
      const footerContainer = document.getElementById('footer-links-container');
      if (!footerContainer) return;

      const portalKeys = ['actualidad', 'tecnologia-ciencia', 'economia-negocios', 'estilo-vida', 'deportes'];

      const html = portalKeys.map(portal => {
        const portalName = PORTAL_NAMES[portal] || portal;
        const portalCats = PORTAL_MAPPING[portal] || [];

        // Generar los enlaces de todas las categorías y subcategorías del portal
        let linksHtml = `
          <a class="footer-sub-link all-link" onclick="selectCategory('${portal}', event)" style="font-weight: 700; border-bottom: 1px dashed rgba(255,255,255,0.08); padding-bottom: 4px; margin-bottom: 4px;">
            PORTAL COMPLETO
          </a>
        `;

        portalCats.forEach(cat => {
          const catName = THEME_NAMES[cat] || cat;
          linksHtml += `
            <a class="footer-sub-link" onclick="selectCategory('${cat}', event)" style="font-weight: 600; text-transform: uppercase; color: var(--accent-cyan); margin-top: 4px;">
              ${catName}
            </a>
          `;

          const subTree = CATEGORY_TREE[cat]?.children || {};
          Object.entries(subTree).forEach(([subKey, subNode]) => {
            linksHtml += `
              <a class="footer-sub-link" onclick="selectSubcategory('${subKey}', '${cat}', event)">
                ${subNode.name}
              </a>
            `;
          });
        });

        return `
          <div class="footer-category-block">
            <div class="footer-category-header" onclick="toggleFooterCategory('${portal}', event)">
              <span class="footer-category-title">${portalName.toUpperCase()}</span>
              <span class="footer-category-arrow">▼</span>
            </div>
            <div class="footer-category-body" id="footer-body-${portal}">
              <div class="footer-category-body-inner">
                ${linksHtml}
              </div>
            </div>
          </div>
        `;
      }).join('');

      footerContainer.innerHTML = html;
    }

    // Alternar categorías en el footer en móvil (acordeón)
    window.toggleFooterCategory = function(cat, event) {
      if (event) event.stopPropagation();
      const body = document.getElementById(`footer-body-${cat}`);
      const header = body.previousElementSibling;
      const arrow = header.querySelector('.footer-category-arrow');
      
      const isOpen = body.classList.contains('open');
      
      // Cerrar todos los demás para efecto acordeón limpio
      document.querySelectorAll('.footer-category-body').forEach(b => {
        b.classList.remove('open');
        b.style.maxHeight = null;
        if (b.previousElementSibling) {
          const arr = b.previousElementSibling.querySelector('.footer-category-arrow');
          if (arr) arr.classList.remove('open');
        }
      });

      if (!isOpen) {
        body.classList.add('open');
        body.style.maxHeight = body.scrollHeight + "px";
        if (arrow) arrow.classList.add('open');
      }
    };

