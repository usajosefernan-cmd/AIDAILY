                              </div>
                            `;
                          } else {
                            return `
                              <div class="drawer-sub-item ${isSubActive ? 'active' : ''}" onclick="selectCategoryAndSubcategoryFromMenu('${cat}', '${subKey}', event)" style="padding-left: 12px;">
