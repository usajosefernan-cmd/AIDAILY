    // Función para saneamiento en origen (unificación y desvíos de categorías/subcategorías)
    function preprocesarArticulo(art) {
      if (!art) return;
      if (!art.category) art.category = 'breaking';
      if (!art.subcategory) art.subcategory = 'General';

      const subNorm = art.subcategory.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();

      // 1. DESVÍOS (Mover artículos a la categoría principal correcta)
      const desvios = {
        'alta cocina y guias gastronomicas': { cat: 'gastronomia', sub: 'Restaurantes' },
        'enologia y bodegas': { cat: 'gastronomia', sub: 'Vinos & Enología' },
        'espacio / astronomia': { cat: 'ciencia', sub: 'Exploración Espacial' },
        'espacio': { cat: 'ciencia', sub: 'Exploración Espacial' },
        'finanzas': { cat: 'economia', sub: 'Finanzas' },
        'educacion': { cat: 'sociedad', sub: 'Educación' },
        'educación': { cat: 'sociedad', sub: 'Educación' },
        'inteligencia artificial': { cat: 'tecnologia', sub: 'Inteligencia Artificial' },
        'criptomonedas, blockchain y web3': { cat: 'tecnologia', sub: 'Cripto & Web3' },
        'blockchain': { cat: 'tecnologia', sub: 'Cripto & Web3' },
        'justicia': { cat: 'nacional', sub: 'Tribunales & Justicia' }
      };

      if (desvios[subNorm]) {
        art.category = desvios[subNorm].cat;
        art.subcategory = desvios[subNorm].sub;
      }

      const catTarget = art.category.toLowerCase().trim();

      // Interceptar salud, bienestar, psicología, nutrición para agruparlos en 'bienestar-salud'
      const isSaludBienestar = 
        catTarget === 'bienestar-salud' ||
        subNorm.includes('bienestar') || 
        subNorm.includes('salud mental') || 
        subNorm.includes('wellness') || 
        subNorm.includes('psicologia') ||
        subNorm.includes('salud y medicina') ||
        subNorm.includes('medicina') ||
        subNorm.includes('biomedicina') ||
        subNorm.includes('nutricion') ||
        subNorm.includes('alimentacion') ||
        (catTarget === 'ciencia' && subNorm.includes('salud')) ||
        (catTarget === 'estilo' && subNorm.includes('salud')) ||
        (catTarget === 'estilo' && subNorm.includes('bienestar'));

      if (isSaludBienestar) {
        art.category = 'bienestar-salud';
        const lp = subNorm;
        if (lp.includes('psicologia') || lp.includes('salud mental') || lp.includes('mente')) {
          art.subcategory = 'Psicología';
        } else if (lp.includes('bienestar') || lp.includes('wellness') || lp.includes('cuidado mental')) {
          art.subcategory = 'Bienestar & Mente';
        } else if (lp.includes('nutricion') || lp.includes('alimentacion') || lp.includes('cuidado del cuerpo')) {
          art.subcategory = 'Nutrición & Cuidado';
        } else {
          art.subcategory = 'Salud & Cuerpo';
        }
        return;
      }

      if (catTarget === 'deportes') {
        const lp = subNorm;
        if (lp.includes('futbol') || lp.includes('la liga') || lp.includes('laliga') || lp.includes('champions') || lp.includes('premier') || lp.includes('copa del rey') || lp.includes('rfef') || lp.includes('balompie')) {
          if (lp.includes('la liga') || lp.includes('laliga')) {
            art.subcategory = 'Fútbol/LaLiga';
          } else if (lp.includes('copa del rey') || lp.includes('rfef') || lp.includes('copa')) {
            art.subcategory = 'Fútbol/Copa & RFEF';
          } else if (lp.includes('champions')) {
            art.subcategory = 'Fútbol/Champions League';
          } else {
            art.subcategory = 'Fútbol';
          }
        } else if (lp.includes('motor') || lp.includes('formula 1') || lp.includes('f1') || lp.includes('motogp') || lp.includes('motociclismo') || lp.includes('rally')) {
          if (lp.includes('formula 1') || lp.includes('f1')) {
            art.subcategory = 'Motor/Fórmula 1';
          } else if (lp.includes('motogp') || lp.includes('motociclismo')) {
            art.subcategory = 'Motor/MotoGP';
          } else {
            art.subcategory = 'Motor';
          }
        } else if (lp.includes('baloncesto') || lp.includes('nba') || lp.includes('acb') || lp.includes('euroliga') || lp.includes('basket')) {
          art.subcategory = 'Baloncesto';
        } else if (lp.includes('tenis') || lp.includes('atp') || lp.includes('wta') || lp.includes('roland') || lp.includes('wimbledon')) {
          art.subcategory = 'Tenis';
        } else if (lp.includes('ciclismo') || lp.includes('vueltas') || lp.includes('ruta') || lp.includes('giro') || lp.includes('tour de francia')) {
          art.subcategory = 'Ciclismo';
        } else {
          art.subcategory = 'Polideportivo';
        }
        return;
      }

      // Internacional
      if (catTarget === 'internacional') {
        const lp = subNorm;
        if (lp.includes('europa')) {
          art.subcategory = 'Europa';
        } else if (lp.includes('america') || lp.includes('ee.uu') || lp.includes('eeuu')) {
          art.subcategory = 'América';
        } else if (lp.includes('oriente medio') || lp.includes('africa')) {
          art.subcategory = 'Oriente Medio & África';
        } else if (lp.includes('asia') || lp.includes('pacifico')) {
          art.subcategory = 'Asia-Pacífico';
        } else {
          art.subcategory = 'Geopolítica & Defensa';
        }
        return;
      }

      // Tecnología
      if (catTarget === 'tecnologia') {
        const lp = subNorm;
        if (lp.includes('inteligencia artificial') || lp.includes('ia') || lp.includes('automatizacion')) {
          if (lp.includes('llms') || lp.includes('modelos') || lp.includes('generativa')) {
            art.subcategory = 'Inteligencia Artificial/LLMs & Modelos';
          } else if (lp.includes('desarrollo') || lp.includes('apis')) {
            art.subcategory = 'Inteligencia Artificial/Desarrollo & APIs';
          } else {
            art.subcategory = 'Inteligencia Artificial/General';
          }
        } else if (lp.includes('redes') || lp.includes('plataformas') || lp.includes('cultura de internet') || lp.includes('redes sociales')) {
          art.subcategory = 'Plataformas & Redes';
        } else if (lp.includes('software') || lp.includes('desarrollo') || lp.includes('open source') || lp.includes('dev')) {
          art.subcategory = 'Software & Dev';
        } else if (lp.includes('hardware') || lp.includes('cuantica') || lp.includes('chips') || lp.includes('semiconductores') || lp.includes('dispositivos')) {
          art.subcategory = 'Hardware & Quantum';
        } else if (lp.includes('ciberseguridad') || lp.includes('privacidad')) {
          art.subcategory = 'Ciberseguridad';
        } else if (lp.includes('videojuegos') || lp.includes('gaming') || lp.includes('juego video')) {
          art.subcategory = 'Videojuegos';
        } else if (lp.includes('startups') || lp.includes('venture')) {
          art.subcategory = 'Startups';
        } else if (lp.includes('blockchain') || lp.includes('cripto') || lp.includes('web3')) {
          art.subcategory = 'Cripto & Web3';
        } else if (lp.includes('smarthome') || lp.includes('iot') || lp.includes('hogar')) {
          art.subcategory = 'Smarthome & IoT';
        } else if (lp.includes('gadgets')) {
          art.subcategory = 'Gadgets & Dispositivos';
        } else {
          art.subcategory = 'General';
        }
        return;
      }

      // Ciencia
      if (catTarget === 'ciencia') {
        const lp = subNorm;
        if (lp.includes('espacio') || lp.includes('astronomia') || lp.includes('cosmologia')) {
          art.subcategory = 'Exploración Espacial';
        } else if (lp.includes('biomedicina') || lp.includes('salud') || lp.includes('medicina') || lp.includes('biologia')) {
          art.subcategory = 'Medicina & Salud';
        } else if (lp.includes('neurociencia') || lp.includes('psicologia')) {
          art.subcategory = 'Neurociencia & Psicología';
        } else {
          art.subcategory = 'Ciencia General';
        }
        return;
      }

      // Cultura
      if (catTarget === 'cultura') {
        const lp = subNorm;
        if (lp.includes('cine') || lp.includes('streaming') || lp.includes('television') || lp.includes('series')) {
          art.subcategory = 'Cine & Streaming';
        } else if (lp.includes('musica')) {
          art.subcategory = 'Música';
        } else if (lp.includes('literatura') || lp.includes('critica') || lp.includes('editorial')) {
          art.subcategory = 'Literatura';
        } else if (lp.includes('arte') || lp.includes('diseño') || lp.includes('museos') || lp.includes('teatro')) {
          art.subcategory = 'Arte & Diseño';
        } else {
          art.subcategory = 'Cultura General';
        }
        return;
      }

      // Medioambiente
      if (catTarget === 'medioambiente') {
        const lp = subNorm;
        if (lp.includes('clima') || lp.includes('sostenibilidad') || lp.includes('cambio climatico') || lp.includes('ecologia') || lp.includes('biodiversidad') || lp.includes('circular')) {
          art.subcategory = 'Clima & Sostenibilidad';
        } else if (lp.includes('renovables') || lp.includes('transicion') || lp.includes('energia')) {
          art.subcategory = 'Energías Renovables';
        } else {
          art.subcategory = 'Medioambiente General';
        }
        return;
      }

      // Nacional
      if (catTarget === 'nacional') {
        const lp = subNorm;
        if (lp.includes('politica') || lp.includes('gobierno')) {
          art.subcategory = 'Política & Gobierno';
        } else if (lp.includes('tribunales') || lp.includes('judiciales') || lp.includes('justicia') || lp.includes('corrupcion')) {
          art.subcategory = 'Tribunales & Justicia';
        } else if (lp.includes('autonomica') || lp.includes('local') || lp.includes('comunidades')) {
          art.subcategory = 'Actualidad Autonómica & Local';
        } else {
          art.subcategory = 'Sociedad';
        }
        return;
      }

      if (catTarget === 'economia') {
        const lp = subNorm;
        if (lp.includes('mercados') || lp.includes('bolsa')) {
          art.subcategory = 'Mercados';
        } else if (lp.includes('finanzas') || lp.includes('inversion') || lp.includes('ahorro') || lp.includes('impuestos') || lp.includes('banca') || lp.includes('vivienda') || lp.includes('hipotecas')) {
