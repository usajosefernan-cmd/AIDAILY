                <span style="font-size: 0.8rem; opacity: 0.6;">${isActive ? '●' : '›'}</span>
              </div>
            </div>
          `;
        }

        const portalCats = PORTAL_MAPPING[portal] || [];
        const isExpanded = isActivePortal;

        return `
          <div class="drawer-category-group">
            <div class="drawer-item ${isActivePortal ? 'active' : ''}" onclick="toggleMobilePortal(event, '${portal}')">
              <span>${portalName}</span>
