    // Sistema de Preferencias en LocalStorage
    function trackUserPreference(category, hashtags) {
      try {
        const prefs = JSON.parse(localStorage.getItem('aidaily_prefs')) || { categories: {}, hashtags: {} };
        if (!prefs.categories) prefs.categories = {};
        if (!prefs.hashtags) prefs.hashtags = {};
        
        if (category) {
          const cat = category.toLowerCase().trim();
          prefs.categories[cat] = (prefs.categories[cat] || 0) + 1;
          if (prefs.categories[cat] > 50) prefs.categories[cat] = 50;
        }
        
        if (Array.isArray(hashtags)) {
          hashtags.forEach(tag => {
            const t = tag.toLowerCase().trim();
            prefs.hashtags[t] = (prefs.hashtags[t] || 0) + 1;
            if (prefs.hashtags[t] > 50) prefs.hashtags[t] = 50;
          });
        }
        
        localStorage.setItem('aidaily_prefs', JSON.stringify(prefs));
      } catch(e) {
        console.warn('Error al guardar preferencias:', e);
      }
    }

    function getArticlePreferenceScore(art) {
      try {
        const prefs = JSON.parse(localStorage.getItem('aidaily_prefs'));
        if (!prefs) return 0;
        
        let score = 0;
        if (art.category && prefs.categories) {
          const cat = art.category.toLowerCase().trim();
          score += (prefs.categories[cat] || 0) * 3;
        }
        
        if (Array.isArray(art.hashtags) && prefs.hashtags) {
          art.hashtags.forEach(tag => {
            const t = tag.toLowerCase().trim();
            score += (prefs.hashtags[t] || 0) * 1;
          });
        }
        
        return score;
      } catch(e) {
        return 0;
      }
    }

    function getSafeTime(art) {
      if (!art) return 0;
      // Priorizar la fecha de publicación real (publishedAt) para que coincida exactamente con la hora relativa mostrada
      let d = art.publishedAt ? new Date(art.publishedAt) : null;
      if (!d || isNaN(d.getTime())) {
        d = art.scrapedAt ? new Date(art.scrapedAt) : null;
      }
      const time = (d && !isNaN(d.getTime())) ? d.getTime() : 0;
      const now = Date.now();
      if (time > now) {
        let scrapeTime = art.scrapedAt ? new Date(art.scrapedAt).getTime() : 0;
        return (scrapeTime && scrapeTime <= now) ? scrapeTime : now;
      }
      return time;
    }

    function sortArticlesPersonalized(articles) {
      return [...articles].sort((a, b) => getSafeTime(b) - getSafeTime(a));
    }

