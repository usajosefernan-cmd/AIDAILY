        let res = await fetch(`/pro/aidaily/api/articles-light.json?nocache=${Date.now()}`).catch(() => null);
        
        // Fallback si no está disponible (desarrollo local, etc.)
        if (!res || !res.ok) {
          console.log("[AIDAILY] Consolidado local ligero no disponible. Cargando de Firebase...");
          res = await fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/articles.json?nocache=${Date.now()}`);
        }
        
        if (res && res.ok) {
          const data = await res.json();
          if (data) {
            const rawList = Array.isArray(data) ? data : Object.values(data);
            const sortedData = [...rawList].sort((a, b) => new Date(b.publishedAt || 0) - new Date(a.publishedAt || 0));
            
            allArticles = sortedData.map(val => {
              const art = {
                ...val,
                id: val.id || val.url
              };
              preprocesarArticulo(art);
              return art;
            });
            
            allArticles = sortArticlesPersonalized(allArticles);
            allArticlesLoaded = true;
            console.log("[AIDAILY] Historial ligero cargado e indexado:", allArticles.length);
          }
        }
      } catch (e) {
        console.error("[AIDAILY] Error cargando historial ligero:", e);
      }
    }
    // RENDERIZAR TEMAS CALIENTES Y SUB-MENÚ DE EVENTOS DINÁMICAMENTE
    function renderTrendingTopics() {
      const bar = document.getElementById('trending-topics-bar');
      const list = document.getElementById('trending-topics-list');
      if (!bar || !list) return;

      const allTopics = Object.values(window.trendingTopics || {})
        .filter(t => t && t.id && t.id !== 'updatedAt' && t.id !== 'windowHours' && t.status === 'active');

      // Filtrar para la marquesina principal: solo temas destacados manualmente, de tipo breaking/event, o de alta popularidad
      const highlightedIds = window.highlightedTopics || [];
      const topics = allTopics.filter(t => {
        const isManualHighlighted = highlightedIds.includes(t.id);
        const isCriticalType = t.type === 'breaking' || t.type === 'event';
        const isHighlyPopular = (t.popularity >= 0.8) || (t.popularity >= 80);
        return isManualHighlighted || isCriticalType || isHighlyPopular;
      });

      if (topics.length === 0) {
        bar.style.display = 'none';
        return;
      }

      // Ordenar por popularidad
      topics.sort((a, b) => (b.popularity || 0) - (a.popularity || 0));

      list.innerHTML = topics.map(t => {
        const isActive = window.activeTrendingTopic && window.activeTrendingTopic.id === t.id;
        const icon = t.type === 'event' ? '🏆' : (t.type === 'breaking' ? '🔥' : '📈');
        const badgeColor = t.type === 'breaking' ? '#ef4444' : (t.type === 'event' ? 'var(--accent-cyan)' : 'var(--accent-purple)');
        
        return `
          <button class="hashtag-btn ${isActive ? 'active' : ''}" 
                  onclick="selectTrendingTopic('${t.id}')"
                  style="margin: 0; display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; font-size: 0.72rem; border-radius: 20px; font-weight: 700; white-space: nowrap; border-color: ${isActive ? badgeColor : 'rgba(255,255,255,0.08)'}; background: ${isActive ? `rgba(${t.type === 'breaking' ? '239,68,68' : '6,182,212'}, 0.15)` : 'rgba(255,255,255,0.02)'}; color: ${isActive ? '#fff' : 'var(--text-muted)'};">
            <span>${icon}</span>
            <span>${t.title}</span>
          </button>
        `;
      }).join('');

      bar.style.display = 'block';
    }

    // SELECCIONAR TEMA CALIENTE Y APLICAR FILTRO
    window.selectTrendingTopic = async function(topicId) {
      if (!allArticlesLoaded) {
        await ensureAllArticlesLoaded();
      }
      const topic = (window._trendingData || []).find(t => t.id === topicId);
      if (!topic) return;
      
      const eventNav = document.getElementById('event-context-nav');
      const eventMenu = document.getElementById('event-context-menu');
      const eventTitle = document.getElementById('event-context-title');
      
      if (window.activeTrendingTopic && window.activeTrendingTopic.id === topicId) {
        // Toggle off
        window.activeTrendingTopic = null;
        searchQuery = '';
        if (eventNav) eventNav.style.display = 'none';
      } else {
        window.activeTrendingTopic = topic;
        searchQuery = ''; // Limpiar búsqueda de texto plano que rompe los filtros
        
        // Redirigir de manera natural a la categoría/subcategoría del tema
        if (topic.category) {
          activeCategory = topic.category;
          if (topic.subcategory) {
            activeSubcategory = topic.subcategory;
          } else {
            activeSubcategory = '';
          }
        }
      
        // Render sub-menus if available
        if (eventNav && eventMenu && topic.subMenus && topic.subMenus.length > 0) {
          if (eventTitle) {
            eventTitle.innerHTML = `<span style="color: var(--accent-cyan);">🏁</span> ${topic.title.toUpperCase()}`;
          }
          eventMenu.innerHTML = topic.subMenus.map(item => {
            const isActive = searchQuery === item.query.toLowerCase().trim();
            return `<button class="hashtag-btn ${isActive ? 'active' : ''}" 
                    onclick="filterByEventSubQuery('${item.query.replace(/'/g, "\\'")}')"
                    style="margin: 0; padding: 4px 10px; font-size: 0.68rem; font-weight: 700; border-radius: 8px;">
              ${item.icon || ''} ${item.label} <span style="font-size:0.6rem;opacity:0.6">(${item.count})</span>
            </button>`;
          }).join('');
          eventNav.style.display = 'block';
        } else if (eventNav) {
          eventNav.style.display = 'none';
        }
      }
      
      currentPage = 1;
      updateURL();
      renderTrendingTopics();
      renderCategories();
      renderSubcategories();
      renderFeed();
    };

    // FILTRAR POR SUB-QUERY DE EVENTO (sub-menús dinámicos)
    window.filterByEventSubQuery = function(subQuery) {
      searchQuery = subQuery.toLowerCase().trim();
      currentPage = 1;
      updateURL();
      
      // Update active state on sub-menu buttons
      const eventMenu = document.getElementById('event-context-menu');
      if (eventMenu) {
        eventMenu.querySelectorAll('.hashtag-btn').forEach(btn => {
          const btnQuery = btn.getAttribute('onclick')?.match(/'([^']+)'/)?.[1] || '';
          btn.classList.toggle('active', btnQuery.toLowerCase().trim() === searchQuery);
        });
      }
      
      renderFeed();
    };

    async function init() {
      try {
        // Iniciar reloj
        updateClock();
        setInterval(updateClock, 30000);

        // Cargar tema guardado
        const savedTheme = localStorage.getItem('aidaily_theme') || 'dark';
        setTheme(savedTheme);

        // Sincronizar el estado inicial del enrutador desde la URL
        syncStateFromURL();


        // Cargar artículos, configuración de feeds, estado de compilación y temas calientes en paralelo
        let articlesData = null;
        let feedsRes = null;
        let statusRes = null;
        let trendsRes = null;

        // Declarar variables globales en window
        window.trendingTopics = {};
        window.activeTrendingTopic = null;
        window.highlightedTopics = [];

        let highlightsRes = null;

        if (window.initialArticles && window.initialArticles.length > 0) {
          articlesData = window.initialArticles;
          console.log("[AIDAILY] Cargando artículos desde datos estáticos iniciales:", articlesData.length);
          const [fRes, sRes, tRes, hRes] = await Promise.all([
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/config/feeds.json?nocache=${Date.now()}`),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/sources_status.json?nocache=${Date.now()}`).catch(() => null),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/trending_topics.json?nocache=${Date.now()}`).catch(() => null),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/config/highlighted_topics.json?nocache=${Date.now()}`).catch(() => null)
          ]);
          feedsRes = fRes;
          statusRes = sRes;
          trendsRes = tRes;
          highlightsRes = hRes;
          
          const isSearchActive = !!(searchQuery || activeHashtag || activeSource || activeSubcategory || activeCategory === 'date');
          if (isSearchActive) {
            console.log("[AIDAILY] Búsqueda o filtro activo en URL al cargar. Forzando carga inmediata del histórico...");
            setTimeout(() => {
              ensureAllArticlesLoaded().then(() => {
                renderCategories();
                renderSubcategories();
                updateHashtagAnalyzer();
                renderFeed();
              });
            }, 300);
          } else {
            console.log("[AIDAILY] Portada limpia detectada. Postponiendo descarga del histórico completo (Lazy Load) para ahorrar RAM.");
          }
          
        } else {
          console.log("[AIDAILY] Datos iniciales no disponibles. Descargando todo...");
          const [articlesRes, fRes, sRes, tRes, hRes] = await Promise.all([
            fetch(`/pro/aidaily/api/articles.json?nocache=${Date.now()}`).catch(() => null),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/config/feeds.json?nocache=${Date.now()}`),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/sources_status.json?nocache=${Date.now()}`).catch(() => null),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/trending_topics.json?nocache=${Date.now()}`).catch(() => null),
            fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/config/highlighted_topics.json?nocache=${Date.now()}`).catch(() => null)
          ]);
          feedsRes = fRes;
          statusRes = sRes;
          trendsRes = tRes;
          highlightsRes = hRes;
          if (articlesRes && articlesRes.ok) {
            const rawData = await articlesRes.json();
            if (rawData) {
              const rawList = Array.isArray(rawData) ? rawData : Object.values(rawData);
              articlesData = rawList.map(val => ({
                ...val,
                id: val.id || val.url
              }));
              allArticlesLoaded = true;
            }
          }
        }

        // Cargar temas destacados
        if (highlightsRes && highlightsRes.ok) {
          try {
            const rawIds = await highlightsRes.json();
            if (Array.isArray(rawIds)) {
              window.highlightedTopics = rawIds;
              console.log("[AIDAILY] Temas destacados cargados:", window.highlightedTopics.length);
            }
          } catch (e) {
            console.error("Error leyendo highlighted_topics:", e);
          }
        }

        // Cargar temas calientes en window.trendingTopics y window._trendingData
        if (trendsRes && trendsRes.ok) {
          try {
            const rawTrends = await trendsRes.json() || {};
            if (rawTrends.topics && Array.isArray(rawTrends.topics)) {
              window._trendingData = rawTrends.topics;
              window.trendingTopics = {};
              rawTrends.topics.forEach(t => {
                window.trendingTopics[t.id] = {
                  ...t,
                  status: 'active'
                };
              });
            } else {
              window.trendingTopics = rawTrends;
              window._trendingData = Object.values(rawTrends);
            }
            console.log("[AIDAILY] Temas calientes dinámicos cargados:", Object.keys(window.trendingTopics).length);
          } catch (e) {
            console.error("Error leyendo trending_topics:", e);
          }
        }

        if (statusRes && statusRes.ok) {
          try {
            const statusData = await statusRes.json();
            if (statusData && statusData.build_status && statusData.build_status.ok === false) {
              showBuildErrorBanner(statusData.build_status.error);
            }
          } catch (e) {
            console.error("Error al procesar el estado de compilación:", e);
          }
        }

        if (!articlesData || articlesData.length === 0) {
          renderEmptyState();
          return;
        }

        // Mapear artículos con fallback de ID y deduplicar semánticamente (Jaccard 6h)
        const sortedData = [...articlesData].sort((a, b) => new Date(b.publishedAt || 0) - new Date(a.publishedAt || 0));
        const seenWordsCache = []; // Array of { words: Set, time: Date }
        
        allArticles = sortedData.map(val => {
          const art = {
            ...val,
            id: val.id || val.url
          };
          preprocesarArticulo(art);
          return art;
        }).filter(art => {
          if (!art.title) return false;
          const artWords = getSignificantWords(art.title);
          const artTime = new Date(art.publishedAt || 0);

          // Buscar duplicados semánticos en las últimas 6 horas
          for (const prev of seenWordsCache) {
            const timeDiffHrs = Math.abs(artTime - prev.time) / (1000 * 60 * 60);
            if (timeDiffHrs <= 6) {
              const similarity = calculateJaccardSimilarity(artWords, prev.words);
              if (similarity >= 0.38) {
                return false;
              }
            }
          }

          seenWordsCache.push({ words: artWords, time: artTime });
          return true;
        });
        allArticles = sortArticlesPersonalized(allArticles);

        // Construir CATEGORY_TREE dinámicamente a partir de la configuración real del Excel de feeds
        if (feedsRes.ok) {
          const feedsData = await feedsRes.json();
          if (feedsData && typeof feedsData === 'object') {
            Object.entries(feedsData).forEach(([cat, list]) => {
              if (Array.isArray(list)) {
                list.forEach(feed => {
                  const sub = (feed.tags && feed.tags[0]) ? feed.tags[0].trim() : 'General';
                  if (sub) {
                    const temp = { category: cat, subcategory: sub };
                    preprocesarArticulo(temp);
                    insertIntoCategoryTree(temp.category, temp.subcategory);
                  }
                });
              }
            });
          }
        }

        // Incorporar además cualquier categoría/subcategoría de artículos huérfanos que pudiesen existir
        allArticles.forEach(art => {
          if (art.category && art.subcategory) {
            insertIntoCategoryTree(art.category, art.subcategory);
          }
        });
        
        renderCategories();
        renderMobileMenu();
        renderSubcategories();
        updateHashtagAnalyzer();
        renderTrendingTopics();
        renderFooter();
        adjustCategoriesVisibility();
        renderFeed();

        // ===== SMART SEARCH AUTOCOMPLETE SYSTEM =====
        let searchSuggestions = [];
        let selectedChips = []; // Array of { label, type }
        let highlightedIdx = -1;
        const chipsContainer = document.getElementById('smart-search-chips');
        const dropdownEl = document.getElementById('smart-search-dropdown');
        
        // Load search index
        (async function loadSearchIndex() {
          try {
            const basePath = document.querySelector('meta[name="base-path"]')?.content || '/pro/aidaily';
            const res = await fetch(`${basePath}/api/search-index.json?t=${Date.now()}`);
            if (res.ok) {
              const data = await res.json();
              searchSuggestions = data.suggestions || [];
              console.log(`[SmartSearch] Loaded ${searchSuggestions.length} suggestions`);
            }
          } catch (e) {
            console.warn('[SmartSearch] Could not load search index:', e.message);
          }
        })();
        
        function renderChips() {
          if (!chipsContainer) return;
          chipsContainer.innerHTML = selectedChips.map((chip, i) => {
            const typeLabels = { category: 'cat', subcategory: 'sub', tag: 'tag', source: 'src', entity: 'ent' };
            const typeClass = typeLabels[chip.type] || 'tag';
            return `<span class="search-chip">
              <span class="chip-type">${typeLabels[chip.type] || chip.type}</span>
              ${chip.label}
              <span class="chip-remove" onclick="removeSearchChip(${i})" title="Quitar">✕</span>
            </span>`;
          }).join('');
        }
        
        window.removeSearchChip = async function(index) {
          selectedChips.splice(index, 1);
          renderChips();
          await updateSearchFromChips();
        };
        
        async function updateSearchFromChips() {
          // Combine chips + free text into searchQuery
          const freeText = searchInput ? searchInput.value.toLowerCase().trim() : '';
          if (selectedChips.length > 0) {
            // Multi-chip: combine all chip labels for filtering
            searchQuery = selectedChips.map(c => c.label.toLowerCase()).join(' ');
            if (freeText && freeText.length > 1) searchQuery += ' ' + freeText;
          } else {
            searchQuery = freeText;
          }
          currentPage = 1;
          updateURL();
          if (searchQuery.length > 2 || selectedChips.length > 0) {
            await ensureAllArticlesLoaded();
          }
          renderFeed();
        }
        
        function showSuggestions(query) {
          if (!dropdownEl || !query || query.length < 1) {
            hideSuggestions();
            return;
          }
          
          const q = query.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const alreadySelected = new Set(selectedChips.map(c => c.label.toLowerCase()));
          
          const matches = searchSuggestions
            .filter(s => {
              const label = s.label.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
              return label.includes(q) && !alreadySelected.has(s.label.toLowerCase());
            })
            .slice(0, 15);
          
          if (matches.length === 0) {
            hideSuggestions();
            return;
          }
          
          // Group by type
          const groups = {};
          const typeOrder = ['category', 'subcategory', 'entity', 'tag', 'source'];
          const typeNames = { category: '📂 Categorías', subcategory: '📁 Subcategorías', entity: '👤 Personas / Entidades', tag: '🏷️ Tags', source: '📰 Fuentes' };
          
          matches.forEach(m => {
            if (!groups[m.type]) groups[m.type] = [];
            groups[m.type].push(m);
          });
          
          let html = '';
          typeOrder.forEach(type => {
            if (!groups[type]) return;
            html += `<div class="search-suggestion-group">
              <div class="search-suggestion-group-label">${typeNames[type] || type}</div>`;
            groups[type].forEach(s => {
              const typeLabels = { category: 'cat', subcategory: 'sub', tag: 'tag', source: 'src', entity: 'ent' };
              const typeClass = typeLabels[s.type] || 'tag';
              html += `<div class="search-suggestion-item" data-label="${s.label.replace(/"/g, '&quot;')}" data-type="${s.type}" onclick="selectSearchSuggestion(this)">
                <span><span class="suggestion-type-badge ${typeClass}">${typeClass}</span> <span class="suggestion-label">${highlightMatch(s.label, query)}</span></span>
                <span class="suggestion-count">${s.count}</span>
              </div>`;
            });
            html += '</div>';
          });
          
          dropdownEl.innerHTML = html;
          dropdownEl.classList.add('visible');
          highlightedIdx = -1;
        }
        
        function highlightMatch(text, query) {
          const idx = text.toLowerCase().indexOf(query.toLowerCase());
          if (idx === -1) return text;
          return text.substring(0, idx) + '<strong style="color:var(--accent-cyan)">' + text.substring(idx, idx + query.length) + '</strong>' + text.substring(idx + query.length);
        }
        
        function hideSuggestions() {
          if (dropdownEl) dropdownEl.classList.remove('visible');
          highlightedIdx = -1;
        }
        
        window.selectSearchSuggestion = async function(el) {
          const label = el.getAttribute('data-label');
          const type = el.getAttribute('data-type');
          selectedChips.push({ label, type });
          renderChips();
          if (searchInput) searchInput.value = '';
          hideSuggestions();
          await updateSearchFromChips();
          if (searchInput) searchInput.focus();
        };
        
        // Listeners del Buscador Inteligente
        if (searchInput) {
          searchInput.addEventListener('focus', () => {
            console.log("[AIDAILY] Foco en buscador inteligente. Cargando histórico en segundo plano...");
            ensureAllArticlesLoaded().then(() => {
              renderCategories();
              renderSubcategories();
              updateHashtagAnalyzer();
              if (searchQuery) renderFeed();
            });
          });
          
          let debounceTimer;
          searchInput.addEventListener('input', (e) => {
            clearTimeout(debounceTimer);
            const val = e.target.value.trim();
            
            // Si hay sugerencias en caché, renderizamos dropdown inmediatamente (es síncrono y rápido)
            if (val.length >= 1 && searchSuggestions.length > 0) {
              showSuggestions(val);
            } else {
              hideSuggestions();
            }
            
            // Retrasar carga pesada asíncrona de búsqueda general para evitar bloqueos
            debounceTimer = setTimeout(async () => {
              if (!allArticlesLoaded) await ensureAllArticlesLoaded();
              
              // Refrescar dropdown tras carga por si venían vacíos
              if (val.length >= 1 && searchSuggestions.length > 0) {
                showSuggestions(val);
              }
              
              await updateSearchFromChips();
            }, 350);
          });
          
          
          // Keyboard navigation in dropdown
          searchInput.addEventListener('keydown', async (e) => {
            const items = dropdownEl ? dropdownEl.querySelectorAll('.search-suggestion-item') : [];
            if (e.key === 'ArrowDown' && items.length > 0) {
              e.preventDefault();
              highlightedIdx = Math.min(highlightedIdx + 1, items.length - 1);
              items.forEach((it, i) => it.classList.toggle('highlighted', i === highlightedIdx));
            } else if (e.key === 'ArrowUp' && items.length > 0) {
              e.preventDefault();
              highlightedIdx = Math.max(highlightedIdx - 1, 0);
              items.forEach((it, i) => it.classList.toggle('highlighted', i === highlightedIdx));
            } else if (e.key === 'Enter' && highlightedIdx >= 0 && items[highlightedIdx]) {
              e.preventDefault();
              items[highlightedIdx].click();
            } else if (e.key === 'Backspace' && searchInput.value === '' && selectedChips.length > 0) {
              // Remove last chip on backspace when input is empty
              selectedChips.pop();
              renderChips();
              await updateSearchFromChips();
            } else if (e.key === 'Escape') {
              hideSuggestions();
            }
          });
        }
        
        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
          if (dropdownEl && !dropdownEl.contains(e.target) && e.target.id !== 'search-input') {
            hideSuggestions();
          }
        });
        // ===== END SMART SEARCH =====

        // Control de Buscador Desplegable en Móvil
        const searchToggleBtn = document.getElementById('search-toggle-btn');
        const searchCloseBtn = document.getElementById('search-close-btn');
        const headerSearchBox = document.getElementById('header-search-box');
        
        if (searchToggleBtn && headerSearchBox && searchCloseBtn && searchInput) {
          searchToggleBtn.addEventListener('click', () => {
            headerSearchBox.classList.add('active');
            searchInput.focus();
          });
          
          searchCloseBtn.addEventListener('click', () => {
            headerSearchBox.classList.remove('active');
            searchInput.value = '';
            searchQuery = '';
            currentPage = 1;
            updateURL();
            renderFeed();
          });

          // Cerrar buscador móvil al hacer clic fuera
          document.addEventListener('click', (e) => {
            if (!headerSearchBox.contains(e.target) && !searchToggleBtn.contains(e.target)) {
              if (headerSearchBox.classList.contains('active')) {
                headerSearchBox.classList.remove('active');
              }
            }
          });
        }

        // Control del Botón Scroll to Top
        const scrollTopBtn = document.getElementById('scroll-top-btn');
        if (scrollTopBtn) {
          window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
              scrollTopBtn.classList.add('visible');
            } else {
              scrollTopBtn.classList.remove('visible');
            }
          });
        }

        // Vincular el selector desplegable de artículos por página v2.1
        const limitSelect = document.getElementById('items-per-page-select');
        if (limitSelect) {
          limitSelect.value = itemsPerPage.toString();
          limitSelect.addEventListener('change', (e) => {
            itemsPerPage = parseInt(e.target.value) || 30;
            localStorage.setItem('aidaily_items_per_page', itemsPerPage);
            currentPage = 1;
            updateURL();
            renderFeed();
          });
        }


        // Event listeners antiguos removidos porque la vista es integrada y no usa modal drawer

        // Listeners del Menú Hamburguesa Móvil
        const menuBtn = document.getElementById('menu-btn');
        const menuCloseBtn = document.getElementById('menu-close-btn');
        const menuOverlay = document.getElementById('menu-overlay');
        const menuDrawer = document.getElementById('menu-drawer');

        if (menuBtn && menuCloseBtn && menuOverlay && menuDrawer) {
          menuBtn.addEventListener('click', () => {
            menuDrawer.classList.add('active');
            menuOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
          });

          const closeMenu = () => {
            menuDrawer.classList.remove('active');
            menuOverlay.classList.remove('active');
            document.body.style.overflow = '';
          };

          menuCloseBtn.addEventListener('click', closeMenu);
          menuOverlay.addEventListener('click', closeMenu);
        }

        // Control de Menú de Temas
        const themeMenuBtn = document.getElementById('theme-menu-btn');
        const themeMenuDropdown = document.getElementById('theme-menu-dropdown');
        if (themeMenuBtn && themeMenuDropdown) {
          themeMenuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            themeMenuDropdown.classList.toggle('active');
          });
          document.addEventListener('click', () => {
            themeMenuDropdown.classList.remove('active');
          });
        }

      } catch (err) {
        console.error(err);
        renderErrorState();
      }
    }

    // Renderizadores del Estado del Feed
    function renderEmptyState() {
      newsFeed.innerHTML = `
        <div class="loading-container" style="text-align: center;">
          <p>No hay artículos disponibles en este momento.</p>
        </div>`;
    }

    function renderErrorState() {
      newsFeed.innerHTML = `
        <div class="loading-container" style="text-align: center;">
          <p>Error de conexión al cargar las noticias. Por favor, recarga la página.</p>
        </div>`;
    }
    function renderDropdownNode(catKey, nodeKey, node, currentPath = '') {
      const fullPath = currentPath ? `${currentPath}/${nodeKey}` : nodeKey;
      const hasChildren = node.children && Object.keys(node.children).length > 0;
      
      if (hasChildren) {
        return `
          <div class="dropdown-submenu">
            <a class="dropdown-sub-link" onclick="selectSubcategory('${fullPath}', '${catKey}', event)">
              <span>${node.name.toUpperCase()}</span> <span class="submenu-caret">▶</span>
            </a>
            <div class="dropdown-submenu-content">
              ${Object.entries(node.children).map(([childKey, childNode]) => {
                return renderDropdownNode(catKey, childKey, childNode, fullPath);
              }).join('')}
            </div>
          </div>
        `;
      } else {
        const isSubActive = (activeCategory === catKey && activeSubcategory === fullPath);
        return `
          <a class="dropdown-sub-link ${isSubActive ? 'active' : ''}" onclick="selectSubcategory('${fullPath}', '${catKey}', event)">
            ${node.name.toUpperCase()}
          </a>
        `;
      }
    }

