    // Renderizar los hashtags dentro del modal
    function renderHashtagsInModal(filterText = '') {
      const modalList = document.getElementById('hashtag-modal-list');
      if (!modalList) return;

      // Calcular hashtags basándose en todos los artículos de la categoría activa
      const hashtagsMap = {};
      const filteredForHashtags = allArticles.filter(art => {
        const hasEnglishWords = /\b(the|and|of|with|from|this|that|about|would|their|there|which)\b/i;
        const isEnglish = hasEnglishWords.test(art.title);
        if (isEnglish) return false;

        if (activeCategory === 'breaking') return true;
        return normalizeText(art.category) === normalizeText(activeCategory);
      });

      filteredForHashtags.forEach(art => {
        const cleanTags = getCleanHashtags(art.hashtags);
        cleanTags.forEach(tag => {
          hashtagsMap[tag] = (hashtagsMap[tag] || 0) + 1;
        });
      });

      // Ordenar por popularidad
      let trending = Object.entries(hashtagsMap).sort((a, b) => b[1] - a[1]);

      // Filtrar por texto si procede
      if (filterText) {
        const cleanFilter = normalizeText(filterText);
        trending = trending.filter(([tag]) => normalizeText(tag).includes(cleanFilter));
      }

      if (trending.length === 0) {
        modalList.innerHTML = `<div style="font-size: 0.8rem; color: var(--text-muted); padding: 12px; width: 100%; text-align: center;">No se encontraron hashtags.</div>`;
        return;
      }

      modalList.innerHTML = trending.map(([tag, count]) => {
        const isActive = tag === activeHashtag;
        return `
          <button class="hashtag-btn ${isActive ? 'active' : ''}" onclick="selectHashtagFromModal('${tag}')" style="margin: 0;">
            <span>${tag}</span>
            <span class="hashtag-count">${count}</span>
