    // Analizador de Hashtags (Trending Tags)
    function updateHashtagAnalyzer() {
      const hashtagsMap = {};
      
      // Filtrar noticias de la categoría activa para analizar sus hashtags
      const filteredForHashtags = allArticles.filter(art => {
        // Exclusión incondicional de noticias en inglés
        const hasEnglishWords = /\b(the|and|of|with|from|this|that|about|would|their|there|which)\b/i;
        const isEnglish = hasEnglishWords.test(art.title);
        if (isEnglish) return false;

        if (activeCategory === 'breaking') return true;
        return normalizeText(art.category) === normalizeText(activeCategory);
      });

      filteredForHashtags.forEach(art => {
        const cleanTags = getCleanHashtags(art.hashtags);
        cleanTags.forEach(tag => {
          hashtagsMap[tag] = (hashtagsMap[tag] || 0) + 1;
        });
      });

      // Ordenar por popularidad (frecuencia)
      const trending = Object.entries(hashtagsMap)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 50); // Top 50 hashtags

      const section = document.getElementById('hashtags-section');
      const navWrapper = document.getElementById('hashtag-nav-wrapper');
      const navContainer = document.getElementById('hashtag-nav-container');

      if (trending.length === 0) {
        if (section) section.style.display = 'none';
        if (navWrapper) navWrapper.style.display = 'none';
        return;
      }
      if (section) section.style.display = 'block';
      if (navWrapper) navWrapper.style.display = 'none'; // Siempre oculto visualmente en v2.1

      // Rellenar Tendencias del Sidebar si existe
      if (hashtagsContainer) {
        hashtagsContainer.innerHTML = trending.map(([tag, count]) => {
          return `
            <button class="hashtag-btn ${tag === activeHashtag ? 'active' : ''}" onclick="selectHashtag('${tag}')">
              <span>${tag}</span>
              <span class="hashtag-count">${count}</span>
            </button>
          `;
        }).join('');
      }

      // Rellenar Marquesina Superior (Ticker automático infinito, con contadores, sin #)
      if (navContainer) {
        const chipsHtml = trending.slice(0, 25).map(([tag, count]) => {
          const cleanName = tag.replace('#', '');
          const isActive = tag === activeHashtag;
          return `
            <button class="hashtag-chip ${isActive ? 'active' : ''}" onclick="selectHashtag('${tag}')">
              <span>${cleanName}</span>
              <span class="hashtag-chip-count">${count}</span>
            </button>
          `;
        }).join('');
        
        // Duplicamos el contenido para la transición de bucle infinito en CSS
        navContainer.innerHTML = chipsHtml + chipsHtml;
      }
    }

