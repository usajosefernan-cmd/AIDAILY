        if (mainFooter) mainFooter.style.display = 'none';
        window.scrollTo({ top: 0, behavior: 'instant' });

        try {
          const cleanId = id.replace(/[^a-zA-Z0-9]/g, '_');
          // Descargar directamente de Firebase RTDB para velocidad inmediata
          const res = await fetch(`https://pecemi-default-rtdb.firebaseio.com/aidaily/articles/${cleanId}.json`);
          if (res.ok) {
            const data = await res.json();
            if (data && data.fullArticle) {
              Object.assign(art, data);
            } else {
              throw new Error("Estructura de artículo incorrecta en la base de datos");
            }
          } else {
            throw new Error(`HTTP ${res.status}`);
          }
        } catch (e) {
          console.warn(`[AIDAILY] Falló fetch de Firebase, intentando API consolidada:`, e.message);
          try {
            // Intentar fetch del consolidado individual si existe
            const basePath = document.querySelector('meta[name="base-path"]')?.content || '/pro/aidaily';
            const res = await fetch(`${basePath}/api/articles/${id}.json`);
            if (res.ok) {
              const data = await res.json();
              Object.assign(art, data);
            }
          } catch (e2) {
            console.error(`[AIDAILY] Fallo total descargando artículo completo:`, e2.message);
            // Contingencia si no hay internet
            art.fullArticle = art.summary || 'El contenido de este artículo no pudo cargarse temporalmente.';
            art.keyPoints = [art.title];
            art.whyMatters = 'Conexión a internet inestable o sin cobertura.';
          }
        }
      }

      // Limpiar y poblar contenedor de artículos infinitos con los datos cargados
      const container = document.getElementById('infinite-articles-container');
      if (container) {
        container.innerHTML = renderArticleItemHtml(art);
      }

      // Calcular recomendados/relacionados semánticos para la cola infinita de lectura (sin sesgo de historial)
      const scored = allArticles
        .filter(a => {
          if (a.id === art.id) return false;
          // Filtrar estrictamente por el mismo tema (misma categoría principal normalizada)
          const catA = normalizeText(a.category);
          const catTarget = normalizeText(art.category);
          return catA && catTarget && catA === catTarget;
        })
        .map(a => {
          let score = 0;
          
          // 1. Coincidencia de Subcategoría (Normalizada)
          const subA = normalizeText(a.subcategory);
          const subTarget = normalizeText(art.subcategory);
          if (subA && subTarget && subA === subTarget) {
            score += 10; // Boost fuerte de subtema
          }
          
          // 2. Coincidencia de Hashtags normalizados en minúsculas y sin '#'
          if (Array.isArray(a.hashtags) && Array.isArray(art.hashtags)) {
            const targetTags = art.hashtags.map(h => normalizeText(h).replace('#', '').trim());
            const aTags = a.hashtags.map(h => normalizeText(h).replace('#', '').trim());
            const commonTags = aTags.filter(t => t && targetTags.includes(t));
            score += commonTags.length * 8; // Peso fuerte a etiquetas compartidas
          }
          
          // 3. Similitud Léxica Jaccard de Titulares
          const titleJaccard = calculateJaccardSimilarityForTitles(art.title, a.title);
          if (titleJaccard > 0.12) {
            score += titleJaccard * 20;
          }
          if (titleJaccard > 0.25) {
            score += 15; // Boost extra por alta similitud (mismo evento/suceso)
          }
          
          return { article: a, score };
        })
        .sort((a, b) => {
          // Si uno coincide en subcategoría y el otro no, el que coincide va primero (mismo subtema prioritario)
          const subA = normalizeText(a.article.subcategory) === normalizeText(art.subcategory) ? 1 : 0;
          const subB = normalizeText(b.article.subcategory) === normalizeText(art.subcategory) ? 1 : 0;
          if (subB !== subA) {
            return subB - subA;
          }
          // A igualdad de coincidencia de subtema, ordenamos estrictamente por fecha de publicación descendente (más recientes primero)
          return getSafeTime(b.article) - getSafeTime(a.article);
        });

      infiniteArticlesQueue = scored.map(s => s.article);
      infiniteNextIndex = 0;

      // Renderizar el botón disparador de carga infinita
      renderInfiniteLoadingTrigger();

      // Configurar IntersectionObserver de scroll de artículos
      setupInfiniteScrollObserver();

      // Configurar observador automático de scroll para el disparador
      setupInfiniteScrollTriggerObserver();

      // Alternar visibilidad de vistas (asegurar estados si no se hizo en la fase asíncrona)
      if (feedLayoutContainer) feedLayoutContainer.style.display = 'none';
      if (articleDetailView) articleDetailView.style.display = 'block';
      const mainFooter = document.getElementById('main-footer');
      if (mainFooter) mainFooter.style.display = 'none';
      
      // Mostrar la subnavegación contextual de la noticia actual
      renderContextualNav(normalizeText(art.category), art.subcategory);
      
      // Scroll to top
      window.scrollTo({ top: 0, behavior: 'instant' });
    };

