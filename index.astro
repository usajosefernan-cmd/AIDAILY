          ${sideTopicsHtml}
        </div>
        <div class="sidebar-section" style="margin-top: 24px;">
          <h3 class="sidebar-title" style="font-family: var(--font-title); font-size: 0.76rem; letter-spacing: 0.5px; border-bottom: 1px solid var(--border-color); padding-bottom: 6px; margin-bottom: 8px; color: var(--accent-purple);">🏷️ TENDENCIAS DE TAGS</h3>
          ${hashtagsHtml}
        </div>
        <div class="sidebar-section" style="margin-top: 24px;">
          <h3 class="sidebar-title" style="font-family: var(--font-title); font-size: 0.76rem; letter-spacing: 0.5px; border-bottom: 1px solid var(--border-color); padding-bottom: 6px; margin-bottom: 8px;">✒️ OPINIÓN Y TRIBUNAS</h3>
          ${opinionHtml}
        </div>
      `;
      sidebarContainer.style.display = 'flex';
    }

    function renderFeed() {
      if (activeCategory === 'date') {
        const mobileTitle = document.getElementById('mobile-section-title');
        if (mobileTitle) {
          const dateObj = new Date(activeDateParam);
          const displayDate = dateObj.toLocaleDateString('es-ES', {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });
          mobileTitle.innerHTML = `📅 Archivo: ${displayDate}`;
        }
      }

      const filteredArticles = getFilteredArticles();
      const quickReelsContainer = document.getElementById('quick-reels-container');
      const sidebarContainer = document.getElementById('nyt-sidebar-container');

      // Calcular paginación v2.1
      const totalItems = filteredArticles.length;
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      if (currentPage > totalPages && totalPages > 0) {
        currentPage = totalPages;
      }

      if (totalItems === 0) {
        if (searchQuery) {
          newsFeed.innerHTML = `
            <div class="loading-container" style="text-align: center; padding: 60px 20px; background: rgba(255,255,255,0.02); border: 1px dashed var(--border-color); border-radius: 16px; margin-top: 10px;">
              <h3 style="font-family: var(--font-title); font-size: 1.1rem; color: #fff; margin-bottom: 6px;">Sin resultados</h3>
              <p style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; max-width: 330px; margin: 0 auto;">
                No encontramos reportes recientes que coincidan con <strong>"${searchQuery}"</strong> en el historial. Intenta con otros términos.
              </p>
            </div>`;
        } else {
          const themeName = THEME_NAMES[activeCategory] || activeCategory;
          newsFeed.innerHTML = `
            <div class="loading-container" style="text-align: center; padding: 60px 20px; background: rgba(255,255,255,0.02); border: 1px dashed var(--border-color); border-radius: 16px; margin-top: 10px;">
              <h3 style="font-family: var(--font-title); font-size: 1.1rem; color: #fff; margin-bottom: 6px;">Espacio de análisis activo</h3>
              <p style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; max-width: 330px; margin: 0 auto;">
                Nuestra IA está rastreando y traduciendo novedades sobre <strong>${themeName}</strong> en este momento. Vuelve en unos minutos para ver los reportes en español.
              </p>
            </div>`;
        }
        if (quickReelsContainer) quickReelsContainer.style.display = 'none';
        renderSidebarContextual();
        const pagWrapper = document.getElementById('pagination-wrapper');
        if (pagWrapper) pagWrapper.style.display = 'none';
        return;
      }

      // Determinar si la subcategoría activa tiene sub-subcategorías en el árbol
      const subTree = activeSubcategory ? CATEGORY_TREE[activeCategory]?.children?.[activeSubcategory] : null;
      const subChildren = subTree?.children ? Object.keys(subTree.children) : [];
      const isSubcategoryPortal = subChildren.length > 0;

      const isSearchActive = !!(searchQuery || activeHashtag || activeSource);

      // --- RENDERIZADO DEL PORTAL CURADO POR CATEGORÍAS (ESTILO NYT) ---
      const isPortal = PORTAL_MAPPING[activeCategory];
      // Comprobar si la categoría activa es una categoría individual con subcategorías (ej. 'internacional')
      const catTree = CATEGORY_TREE[activeCategory];
      const catChildren = catTree ? Object.keys(catTree.children || {}) : [];
      const isCategoryWithSubs = !isPortal && catChildren.length > 0;

      if (((isPortal || isCategoryWithSubs) && !activeSubcategory || isSubcategoryPortal) && !isSearchActive && currentPage === 1) {
        let portalHtml = ``;

        if (isSubcategoryPortal) {
          // --- PORTAL DE SUBCATEGORÍA (Nivel 3: ej. ia, europa) ---
          subChildren.forEach(subSubKey => {
            const subSubNode = subTree.children[subSubKey];
            const sectionName = subSubNode.name || subSubKey;

            // Filtrar artículos para esta sub-subcategoría
            const expectedPath = `${activeSubcategory.toLowerCase()}/${subSubKey.toLowerCase()}`;
            let catArticles = filteredArticles.filter(art => {
              const artPath = getNormalizedSubcatPath(art.category, art.subcategory)?.toLowerCase() || '';

              // Filtro por fecha en la vista de archivo histórico
              if (typeof activeDateParam !== 'undefined' && activeDateParam) {
                try {
                  const artDateStr = new Date(art.publishedAt).toISOString().split('T')[0];
                  if (artDateStr !== activeDateParam) return false;
                } catch(e) {
                  return false;
                }
              }

              if (subSubKey === 'general') {
                return artPath === expectedPath || artPath === activeSubcategory.toLowerCase() || artPath === `${activeSubcategory.toLowerCase()}/general`;
              }
              return artPath === expectedPath;
            });

            if (catArticles.length === 0) {
              portalHtml += `
                <section class="portal-vertical-section">
                  <div class="portal-section-header">
                    <div class="portal-section-title-wrap">
                      <h3 class="portal-section-title">${sectionName}</h3>
                    </div>
                  </div>
                  <div style="font-size: 0.76rem; color: var(--text-muted); padding: 20px; background: rgba(255,255,255,0.01); border: 1px dashed var(--border-color); border-radius: 12px; text-align: center;">
                    No hay reportes archivados en ${sectionName} en esta fecha.
                  </div>
                </section>
              `;
              return;
            }

            // Lead Story (1 artículo)
            const leadArt = catArticles[0];
            const leadImgUrl = getArticleImageUrl(leadArt);
            const leadDateStr = formatRelativeDate(leadArt.publishedAt);

            // Secondary Stories (hasta 2 artículos)
            const secondaryArticles = catArticles.slice(1, 3);
            let secondaryHtml = '';
            if (secondaryArticles.length > 0) {
              secondaryHtml = secondaryArticles.map(secArt => {
                const secDateStr = formatRelativeDate(secArt.publishedAt);
                return `
                  <div class="portal-secondary-item" onclick="openArticle('${secArt.id}')">
                    <span class="portal-secondary-meta">${secArt.source.toUpperCase()} • ${secDateStr}</span>
                    <h4 class="portal-secondary-title">${secArt.title}</h4>
                    <p class="portal-secondary-summary">${secArt.summary}</p>
                    <div class="portal-secondary-footer">
                      <span style="color: var(--accent-cyan); font-weight: 600; font-size: 0.68rem;">Leer →</span>
                    </div>
                  </div>
                `;
              }).join('');
            } else {
              secondaryHtml = `<div style="font-size: 0.72rem; color: var(--text-muted); padding: 20px 0; text-align: center;">No hay reportes secundarios en esta fecha.</div>`;
            }

            const fullPath = `${activeSubcategory}/${subSubKey}`;
            portalHtml += `
              <section class="portal-vertical-section">
                <div class="portal-section-header">
                  <div class="portal-section-title-wrap">
                    <h3 class="portal-section-title">${sectionName}</h3>
                    <a class="portal-section-more" onclick="selectSubcategory('${fullPath}', '${activeCategory}', event)">
                      Ver todo en ${sectionName} <span>→</span>
                    </a>
                  </div>
                </div>

                <div class="portal-news-grid">
                  <!-- Columna Izquierda: Destacada -->
                  <div class="portal-lead-column" onclick="openArticle('${leadArt.id}')">
                    <div class="portal-lead-img-wrapper">
                      <img class="portal-lead-img" src="${leadImgUrl}" alt="${escapeHtmlAttr(leadArt.title)}" loading="lazy">
                    </div>
                    <span class="portal-lead-meta">${leadArt.source.toUpperCase()}</span>
                    <h4 class="portal-lead-title">${leadArt.title}</h4>
                    <p class="portal-lead-summary">${leadArt.summary}</p>
                    <div class="portal-lead-footer">
                      <span>RSS: ${leadDateStr}</span>
                      <span style="color: var(--accent-cyan); font-weight: 600;">Reporte completo →</span>
                    </div>
                  </div>

                  <!-- Columna Derecha: Secundarias -->
                  <div class="portal-side-column">
                    ${secondaryHtml}
                  </div>
                </div>
              </section>
            `;
          });
        } else {
          // --- PORTAL DE CATEGORÍA / PORTAL PRINCIPAL (Nivel 1 o 2) ---
          // Para portales: usar las categorías hijas. Para categorías individuales con subcategorías:
          // mostrar secciones agrupadas por la subcategoría
          const portalCats = isPortal ? PORTAL_MAPPING[activeCategory] : [activeCategory];

          portalCats.forEach(childCat => {
            const childName = THEME_NAMES[childCat] || childCat;
            const childDesc = CATEGORY_DESCRIPTIONS[childCat] || '';

            // Obtener artículos de esta categoría
            let catArticles = allArticles.filter(art => normalizeText(art.category) === normalizeText(childCat));

            // Filtrar por fecha en la vista de archivo histórico
            if (typeof activeDateParam !== 'undefined' && activeDateParam) {
              catArticles = catArticles.filter(art => {
                try {
                  return new Date(art.publishedAt).toISOString().split('T')[0] === activeDateParam;
                } catch(e) {
                  return false;
                }
              });
            }

            if (catArticles.length === 0) {
              portalHtml += `
                <section class="portal-vertical-section">
                  <div class="portal-section-header">
                    <div class="portal-section-title-wrap">
                      <h3 class="portal-section-title">${childName}</h3>
                    </div>
                    <p class="portal-section-description">${childDesc}</p>
                  </div>
                  <div style="font-size: 0.76rem; color: var(--text-muted); padding: 20px; background: rgba(255,255,255,0.01); border: 1px dashed var(--border-color); border-radius: 12px; text-align: center;">
                    No hay reportes archivados para esta sección en esta fecha.
                  </div>
                </section>
              `;
              return;
            }

            // Subcategorías de la sección para el subnav
            const subTree = CATEGORY_TREE[childCat]?.children || {};
            let subnavHtml = '';
            const subEntries = Object.entries(subTree);
            if (subEntries.length > 0) {
              subnavHtml = `
                <div class="portal-section-subnav">
                  <span class="portal-section-subnav-label">Apartados:</span>
                  ${subEntries.slice(0, 8).map(([subKey, subNode]) => `
                    <a class="portal-section-subnav-link" onclick="selectSubcategory('${subKey}', '${childCat}', event)">
                      ${subNode.name}
                    </a>
                  `).join('')}
                </div>
              `;
            }

            // Lead Story (1 artículo)
            const leadArt = catArticles[0];
            const leadImgUrl = getArticleImageUrl(leadArt);
            const leadDateStr = formatRelativeDate(leadArt.publishedAt);

            // Secondary Stories (hasta 2 artículos)
            const secondaryArticles = catArticles.slice(1, 3);
            let secondaryHtml = '';
            if (secondaryArticles.length > 0) {
              secondaryHtml = secondaryArticles.map(secArt => {
                const secDateStr = formatRelativeDate(secArt.publishedAt);
                return `
                  <div class="portal-secondary-item" onclick="openArticle('${secArt.id}')">
                    <span class="portal-secondary-meta">${secArt.source.toUpperCase()} • ${secDateStr}</span>
                    <h4 class="portal-secondary-title">${secArt.title}</h4>
                    <p class="portal-secondary-summary">${secArt.summary}</p>
                    <div class="portal-secondary-footer">
                      <span style="color: var(--accent-cyan); font-weight: 600; font-size: 0.68rem;">Leer →</span>
                    </div>
                  </div>
                `;
              }).join('');
            } else {
              secondaryHtml = `<div style="font-size: 0.72rem; color: var(--text-muted); padding: 20px 0; text-align: center;">No hay reportes secundarios en esta fecha para esta sección.</div>`;
            }

            portalHtml += `
              <section class="portal-vertical-section">
                <div class="portal-section-header">
                  <div class="portal-section-title-wrap">
                    <h3 class="portal-section-title">${childName}</h3>
                    <a class="portal-section-more" onclick="selectCategory('${childCat}')">
                      Ver todo en ${childName} <span>→</span>
                    </a>
                  </div>
                  <p class="portal-section-description">${childDesc}</p>
                  ${subnavHtml}
                </div>

                <div class="portal-news-grid">
                  <!-- Columna Izquierda: Destacada -->
                  <div class="portal-lead-column" onclick="openArticle('${leadArt.id}')">
                    <div class="portal-lead-img-wrapper">
                      <img class="portal-lead-img" src="${leadImgUrl}" alt="${escapeHtmlAttr(leadArt.title)}" loading="lazy">
                    </div>
                    <span class="portal-lead-meta">${leadArt.source.toUpperCase()}</span>
                    <h4 class="portal-lead-title">${leadArt.title}</h4>
                    <p class="portal-lead-summary">${leadArt.summary}</p>
                    <div class="portal-lead-footer">
                      <span>RSS: ${leadDateStr}</span>
                      <span style="color: var(--accent-cyan); font-weight: 600;">Reporte completo →</span>
                    </div>
                  </div>

                  <!-- Columna Derecha: Secundarias -->
                  <div class="portal-side-column">
                    ${secondaryHtml}
                  </div>
                </div>
              </section>
            `;
          });
        }

        newsFeed.innerHTML = portalHtml;

        if (quickReelsContainer) quickReelsContainer.style.display = 'none';
        if (sidebarContainer) sidebarContainer.style.display = 'none';
        const pagWrapper = document.getElementById('pagination-wrapper');
        if (pagWrapper) pagWrapper.style.display = 'none';
        return;
      }

      let htmlContent = '';
      let startIndex = 0;
      let pageArticles = [];

      // 1. Renderizar Carrusel Horizontal de Destacados (Quick Reels - Stories de Tendencias)
      // Solo en página 1 y sin búsqueda activa
      if (currentPage === 1 && !isSearchActive && quickReelsContainer) {
        // Obtener todos los temas calientes activos
        const allTopics = Object.values(window.trendingTopics || {})
          .filter(t => t && t.id && t.id !== 'updatedAt' && t.id !== 'windowHours');

        // Helper para buscar el artículo más representativo del tema
        function getArticleForTopic(topic) {
          const keywords = topic.keywords || [topic.title];
          return allArticles.find(art => {
            return keywords.some(kw => {
              const q = kw.toLowerCase().trim();
              const titleText = (art.title || '').toLowerCase();
              const summaryText = (art.summary || '').toLowerCase();
              const cleanTags = getCleanHashtags(art.hashtags).map(h => h.toLowerCase());
              return titleText.includes(q) || summaryText.includes(q) || cleanTags.some(h => h.includes(q));
            });
          });
        }

        let reelsHtml = '';
        let count = 0;

        // Renderizar un Story vertical por cada tema de actualidad (minimalista: sin badges ni fuentes)
        for (const t of allTopics) {
          if (count >= 8) break; // Máximo 8 Stories en el carrusel superior
          const art = getArticleForTopic(t);
          if (art) {
            count++;
            const imgUrl = getArticleImageUrl(art);
            
            reelsHtml += `
              <div class="reel-item" onclick="openArticle('${art.id}')" title="Ver tema: ${escapeHtmlAttr(t.title)}">
                <div class="reel-img-wrapper">
                  <img class="reel-img" src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}" loading="lazy">
                </div>
                <div class="reel-content-wrapper">
                  <p class="reel-topic-title">${t.title.toUpperCase()}</p>
                  <h4 class="reel-title">${art.title}</h4>
                </div>
              </div>
            `;
          }
        }

        // Fallback: Si no hay suficientes temas de actualidad o artículos en tendencia, rellenamos con artículos destacados del feed (minimalista)
        if (count < 3) {
          const fallbackArticles = filteredArticles.slice(1, 8);
          reelsHtml = fallbackArticles.map(art => {
            const catKey = (art.category || 'general').toLowerCase();
            const themeName = THEME_NAMES[catKey] || 'General';
            const imgUrl = getArticleImageUrl(art);
            return `
              <div class="reel-item" onclick="openArticle('${art.id}')">
                <div class="reel-img-wrapper">
                  <img class="reel-img" src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}" loading="lazy">
                </div>
                <div class="reel-content-wrapper">
                  <p class="reel-topic-title" style="color: var(--accent-purple);">${themeName.toUpperCase()}</p>
                  <h4 class="reel-title">${art.title}</h4>
                </div>
              </div>
            `;
          }).join('');
        }

        quickReelsContainer.innerHTML = reelsHtml;
        quickReelsContainer.style.display = 'flex';
      } else {
        if (quickReelsContainer) quickReelsContainer.style.display = 'none';
      }

      // 2. Renderizar Portada de Periódico de 3 Columnas (Lead + Middle + Side Stories) en la columna principal
      // Solo en la página 1 y sin búsqueda activa
      if (currentPage === 1 && !isSearchActive && filteredArticles[0]) {
        const lead = filteredArticles[0];
        const leadImgUrl = getArticleImageUrl(lead);
        const leadCategoryKey = (lead.category || 'general').toLowerCase();
        const leadThemeName = THEME_NAMES[leadCategoryKey] || 'General';
        const leadDateStr = formatRelativeDate(lead.publishedAt);
        
        // Noticia central secundaria (Noticia 2)
        const middle = filteredArticles[1];
        let middleHtml = '';
        if (middle) {
          const middleImgUrl = getArticleImageUrl(middle);
          const middleCategoryKey = (middle.category || 'general').toLowerCase();
          const middleThemeName = THEME_NAMES[middleCategoryKey] || 'General';
          const middleDateStr = formatRelativeDate(middle.publishedAt);
          middleHtml = `
            <div class="nyt-middle-column" onclick="openArticle('${middle.id}')">
              <div class="lead-story-image-wrapper" style="max-height: 180px;">
                <img class="lead-story-img" src="${middleImgUrl}" alt="${escapeHtmlAttr(middle.title)}" loading="lazy">
              </div>
              <span class="card-source" style="font-size: 0.65rem; color: var(--accent-cyan); text-transform: uppercase; font-weight: 800; margin-top: 4px;">${middleThemeName.toUpperCase()}</span>
              <h3 class="side-story-title" style="font-size: 1.15rem;">${middle.title}</h3>
              <p class="side-story-summary" style="font-size: 0.78rem;">${middle.summary}</p>
              <div style="font-size: 0.65rem; color: var(--text-muted); display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border-color); padding-top: 8px;">
                <span>RSS: ${middleDateStr}</span>
                <span style="color: var(--accent-cyan); font-weight: 600;">Leer →</span>
              </div>
            </div>
          `;
        }

        // Side-stories (Noticias 3, 4 y 5) en columna derecha
        const startIndexSides = middle ? 2 : 1;
        const sides = filteredArticles.slice(startIndexSides, startIndexSides + 3);
        let sideStoriesHtml = '';
        if (sides.length > 0) {
          sideStoriesHtml = sides.map(side => {
            const sideCategoryKey = (side.category || 'general').toLowerCase();
            const sideThemeName = THEME_NAMES[sideCategoryKey] || 'General';
            const sideDateStr = formatRelativeDate(side.publishedAt);
            return `
              <div class="side-story-item" onclick="openArticle('${side.id}')" style="display: flex; flex-direction: column; gap: 4px;">
                <span class="card-source" style="font-size: 0.65rem; color: var(--accent-cyan); text-transform: uppercase; font-weight: 800;">${sideThemeName.toUpperCase()}</span>
                <h4 class="side-story-title" style="font-size: 0.88rem; line-height: 1.25;">${side.title}</h4>
                <p class="side-story-summary" style="font-size: 0.74rem; line-height: 1.35;">${side.summary}</p>
                <span style="font-size: 0.62rem; color: var(--text-muted);">${sideDateStr}</span>
              </div>
            `;
          }).join('');
        }

        htmlContent += `
          <div class="nyt-front-page-3col">
            <!-- Columna Izquierda: Noticia Destacada Principal -->
            <div class="nyt-lead-column" onclick="openArticle('${lead.id}')">
              <div class="lead-story-image-wrapper">
                <img class="lead-story-img" src="${leadImgUrl}" alt="${escapeHtmlAttr(lead.title)}" loading="lazy">
              </div>
              <span class="card-source" style="font-size: 0.7rem; color: var(--accent-cyan); text-transform: uppercase; font-weight: 800; margin-top: 4px;">${leadThemeName.toUpperCase()}</span>
              <h2 class="lead-story-title" style="font-size: 1.45rem;">${lead.title}</h2>
              <p class="lead-story-summary">${lead.summary}</p>
              <div style="font-size: 0.7rem; color: var(--text-muted); display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border-color); padding-top: 8px;">
                <span>RSS: ${leadDateStr}</span>
                <span style="color: var(--accent-cyan); font-weight: 600;">Leer reporte completo →</span>
              </div>
            </div>
            
            <!-- Columna Central: Noticia Secundaria Destacada -->
            ${middleHtml}
            
            <!-- Columna Derecha: Otras Noticias (Análisis y Resúmenes) -->
            <div class="nyt-side-column">
              <h3 style="font-family: var(--font-title); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1.5px solid var(--text-title); padding-bottom: 6px; color: var(--text-title); margin-bottom: 10px;">Otras Noticias</h3>
              ${sideStoriesHtml || '<div style="font-size: 0.72rem; color: var(--text-muted);">No hay reportes secundarios hoy.</div>'}
            </div>
          </div>
        `;
        
        // Saltamos las noticias que ya renderizamos en la portada (hasta 5 artículos)
        startIndex = Math.min(filteredArticles.length, middle ? 5 : 4);
        pageArticles = filteredArticles.slice(startIndex, itemsPerPage);
      } else {
        // En página > 1 o si hay búsqueda activa: renderizar todos los artículos correspondientes en tarjetas compactas
        pageArticles = filteredArticles.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
      }

      // Renderizar el resto de noticias en tarjetas horizontales compactas (.row-card)
      htmlContent += renderArticlesBatchHtml(pageArticles);
      newsFeed.innerHTML = htmlContent;

      // 3. Renderizar Sidebar Lateral (Solo Escritorio)
      renderSidebarContextual();

      // 4. Renderizar botonera de paginación clásica v2.1
      renderPagination(totalPages, totalItems);
    }

    // Dibujar botonera e info de paginación v2.1
    function renderPagination(totalPages, totalItems) {
      const wrapper = document.getElementById('pagination-wrapper');
      const container = document.getElementById('pagination-controls-container');
      const totalInfo = document.getElementById('pagination-total-info');
      const limitSelect = document.getElementById('items-per-page-select');

      if (!wrapper || !container) return;

      if (totalPages <= 1) {
        wrapper.style.display = 'none';
        return;
      }

      wrapper.style.display = 'flex';

      // Actualizar información del rango mostrado
      const startIdx = (currentPage - 1) * itemsPerPage + 1;
      const endIdx = Math.min(currentPage * itemsPerPage, totalItems);
      if (totalInfo) {
        totalInfo.innerText = `${startIdx}-${endIdx} de ${totalItems} reportes`;
      }

      // Sincronizar el selector desplegable
      if (limitSelect) {
        limitSelect.value = itemsPerPage.toString();
      }

      // Construir botones
      let controlsHtml = '';

      // Botón Anterior
      controlsHtml += `
        <button class="pagination-btn" ${currentPage === 1 ? 'disabled' : ''} onclick="changePage(${currentPage - 1})" title="Página anterior">
          ◀ Anterior
        </button>
      `;

      // Rango de páginas inteligente con puntos suspensivos
      const pagesToShow = [];
      const delta = 2; // Páginas colindantes a mostrar

      pagesToShow.push(1);

      for (let i = Math.max(2, currentPage - delta); i <= Math.min(totalPages - 1, currentPage + delta); i++) {
        pagesToShow.push(i);
      }

      if (totalPages > 1) {
        pagesToShow.push(totalPages);
      }

      let lastPage = 0;
      pagesToShow.forEach(page => {
        if (lastPage > 0) {
          if (page - lastPage === 2) {
            controlsHtml += `<button class="pagination-btn" onclick="changePage(${lastPage + 1})">${lastPage + 1}</button>`;
          } else if (page - lastPage > 2) {
            controlsHtml += `<span class="pagination-dots">...</span>`;
          }
        }

        controlsHtml += `
          <button class="pagination-btn ${page === currentPage ? 'active' : ''}" onclick="changePage(${page})">
            ${page}
          </button>
        `;
        lastPage = page;
      });

      // Botón Siguiente
      controlsHtml += `
        <button class="pagination-btn" ${currentPage === totalPages ? 'disabled' : ''} onclick="changePage(${currentPage + 1})" title="Página siguiente">
          Siguiente ▶
        </button>
      `;

      container.innerHTML = controlsHtml;
    }

    // Callback de cambio de página
    window.changePage = function(page) {
      currentPage = page;
      updateURL();
      renderFeed();

      // Scroll suave hasta el feed para no perder foco
      const feedContainer = document.getElementById('feed-layout-container');
      if (feedContainer) {
        window.scrollTo({
          top: feedContainer.offsetTop - 80,
          behavior: 'smooth'
        });
      }
    };


    function renderArticleBodyHtml(art) {
      if (!art) return '';
      
      let html = '';
      let paragraphs = [];
      if (art.fullArticle) {
        // Sanear placeholders rotos con saltos de línea accidentales dentro de la directiva multimedia
        const sanitizedArticle = art.fullArticle.replace(/\[MULTIMEDIA:\s*([\s\S]*?)\]/g, (match, url) => {
          return `[MULTIMEDIA: ${url.replace(/\s+/g, '')}]`;
        });
        paragraphs = sanitizedArticle.split(/\n\n+/).filter(p => p.trim().length > 0);
      } else {
        paragraphs = [art.summary || 'Noticia relevante redactada por IA.'];
      }
      
      // Rastreador de recursos renderizados mediante placeholders
      const renderedUrls = new Set();
      
      // Omitir portada del renderizado inline
      if (art.imageUrl) {
        renderedUrls.add(art.imageUrl);
      }

      paragraphs.forEach((p) => {
        const trimmed = p.trim();
        // Buscar el formato [MULTIMEDIA: URL] en cualquier posición del párrafo
        const match = trimmed.match(/\[MULTIMEDIA:\s*(https?:\/\/[^\]\s]+)\]/i);
        if (match) {
          const mediaUrl = match[1].trim();
          // Buscar el recurso en el array multimedia de la noticia
          const mediaItem = Array.isArray(art.multimedia) ? art.multimedia.find(m => m.url === mediaUrl) : null;
          
          if (mediaItem) {
            renderedUrls.add(mediaItem.url);
            const captionEscaped = escapeHtmlAttr(mediaItem.caption || 'Recurso de la noticia');
            const captionHtml = mediaItem.caption ? `<div class="inline-image-caption" style="text-align: center; margin-top: 8px; font-size: 0.78rem; color: var(--text-muted); font-style: italic;">${mediaItem.caption}</div>` : '';
            
            if (mediaItem.type === 'youtube') {
              let embedUrl = mediaItem.url;
              if (embedUrl.includes('watch?v=')) {
                embedUrl = embedUrl.replace('watch?v=', 'embed/');
              } else if (embedUrl.includes('youtu.be/')) {
                embedUrl = embedUrl.replace('youtu.be/', 'youtube.com/embed/');
              }
              html += `
                <div class="inline-article-video-container" style="margin: 24px 0; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 12px 32px rgba(0,0,0,0.5); aspect-ratio: 16/9; background: #000;">
                  <iframe src="${embedUrl}" style="width: 100%; height: 100%; border: none;" allowfullscreen loading="lazy"></iframe>
                  ${captionHtml}
                </div>
              `;
            } else if (mediaItem.type === 'twitter') {
              html += `
                <div class="inline-article-tweet-container" style="margin: 24px auto; max-width: 550px; background: rgba(255,255,255,0.02); border-radius: 12px; padding: 16px; border: 1px solid var(--border-color);">
                  <blockquote class="twitter-tweet" data-theme="dark" data-align="center">
                    <a href="${mediaItem.url}"></a>
                  </blockquote>
                  <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"><` + `/script>
                  ${captionHtml}
                </div>
              `;
            } else if (mediaItem.type === 'video') {
              html += `
                <div class="inline-article-video-container" style="margin: 24px 0; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 12px 32px rgba(0,0,0,0.5); aspect-ratio: 16/9; background: #000;">
                  <video src="${mediaItem.url}" controls style="width: 100%; height: 100%;" loading="lazy"></video>
                  ${captionHtml}
                </div>
              `;
            } else {
              // Imagen normal
              html += `
                <div class="inline-article-image-container" style="margin: 24px 0;">
                  <img class="inline-article-image" src="${mediaItem.url}" alt="${captionEscaped}" onclick="openLightbox('${mediaItem.url}', '${captionEscaped}', '${art.id}')" loading="lazy">
                  ${captionHtml}
                </div>
              `;
            }
          }
          const textRemaining = trimmed.replace(match[0], '').trim();
          if (textRemaining.length > 0) {
            html += `<p style="margin-bottom: 16px; line-height: 1.6;">${textRemaining}</p>`;
          }
        } else {
          // Renderizar como párrafo de texto normal
          html += `<p style="margin-bottom: 16px; line-height: 1.6;">${trimmed}</p>`;
        }
      });

      // Renderizar cualquier multimedia adicional que NO haya sido intercalada mediante placeholders (soporte heredado y robustez)
      let extraMediaHtml = '';
      if (Array.isArray(art.multimedia)) {
        const remainingMedia = art.multimedia.filter(m => !renderedUrls.has(m.url));
        if (remainingMedia.length > 0) {
          // Si hay imágenes restantes, las mostramos agrupadas o intercaladas
          const remainingImages = remainingMedia.filter(m => m.type === 'image');
          const remainingOthers = remainingMedia.filter(m => m.type !== 'image');
          
          if (remainingImages.length > 2) {
            // Mostrar como galería
            extraMediaHtml += `
              <div style="margin-top: 24px; margin-bottom: 24px;">
                <h4 style="font-family: var(--font-title); font-size: 0.9rem; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Galería de Imágenes</h4>
                <div class="article-multimedia-gallery">
                  ${remainingImages.map(img => {
                    const captionEscaped = escapeHtmlAttr(img.caption || 'Imagen de la noticia');
                    return `
                      <div class="gallery-card-item" onclick="openLightbox('${img.url}', '${captionEscaped}', '${art.id}')">
                         <img class="gallery-card-img" src="${img.url}" alt="${captionEscaped}" loading="lazy">
                         ${img.caption ? `<div class="gallery-card-caption">${img.caption}</div>` : ''}
                      </div>
                    `;
                  }).join('')}
                </div>
              </div>
            `;
          } else {
            // Mostrar imágenes una debajo de otra
            remainingImages.forEach(img => {
              const captionEscaped = escapeHtmlAttr(img.caption || 'Imagen relacionada');
              extraMediaHtml += `
                <div class="inline-article-image-container" style="margin: 24px 0;">
                  <img class="inline-article-image" src="${img.url}" alt="${captionEscaped}" onclick="openLightbox('${img.url}', '${captionEscaped}', '${art.id}')" loading="lazy">
                  ${img.caption ? `<div class="inline-image-caption">${img.caption}</div>` : ''}
                </div>
              `;
            });
          }
          
          // Otros formatos (videos, tweets) restantes
          remainingOthers.forEach(m => {
            const captionHtml = m.caption ? `<div class="inline-image-caption" style="text-align: center; margin-top: 8px; font-size: 0.78rem; color: var(--text-muted); font-style: italic;">${m.caption}</div>` : '';
            if (m.type === 'youtube') {
              let embedUrl = m.url;
              if (embedUrl.includes('watch?v=')) {
                embedUrl = embedUrl.replace('watch?v=', 'embed/');
              } else if (embedUrl.includes('youtu.be/')) {
                embedUrl = embedUrl.replace('youtu.be/', 'youtube.com/embed/');
              }
              extraMediaHtml += `
                <div class="inline-article-video-container" style="margin: 28px 0; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 12px 32px rgba(0,0,0,0.5); aspect-ratio: 16/9; background: #000;">
                  <iframe src="${embedUrl}" style="width: 100%; height: 100%; border: none;" allowfullscreen loading="lazy"></iframe>
                  ${captionHtml}
                </div>
              `;
            } else if (m.type === 'twitter') {
              extraMediaHtml += `
                <div class="inline-article-tweet-container" style="margin: 28px auto; max-width: 550px; background: rgba(255,255,255,0.02); border-radius: 12px; padding: 16px; border: 1px solid var(--border-color);">
                  <blockquote class="twitter-tweet" data-theme="dark" data-align="center">
                    <a href="${m.url}"></a>
                  </blockquote>
                  <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"><` + `/script>
                  ${captionHtml}
                </div>
              `;
            } else if (m.type === 'video') {
              extraMediaHtml += `
                <div class="inline-article-video-container" style="margin: 28px 0; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 12px 32px rgba(0,0,0,0.5); aspect-ratio: 16/9; background: #000;">
                  <video src="${m.url}" controls style="width: 100%; height: 100%;" loading="lazy"></video>
                  ${captionHtml}
                </div>
              `;
            }
          });
        }
      }
      html += extraMediaHtml;

      // Sección de Enlaces de Interés
      if (Array.isArray(art.links) && art.links.length > 0) {
        html += `
          <div style="margin-top: 24px; padding: 16px 20px; background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(255, 255, 255, 0.03) 100%); border-radius: 12px; border: 1px solid var(--border-color);">
            <h4 style="font-family: var(--font-title); font-size: 0.82rem; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
              <span>🔗</span> Enlaces de Interés
            </h4>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              ${art.links.map(l => `
                <a href="${l.url}" target="_blank" style="display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; background: rgba(0,0,0,0.18); border: 1px solid rgba(255,255,255,0.03); border-radius: 8px; color: var(--text-title); text-decoration: none; font-size: 0.8rem; font-weight: 500; transition: all 0.2s ease; gap: 12px; min-width: 0;" onmouseover="this.style.borderColor='var(--accent-cyan)'; this.style.transform='translateX(2px)';" onmouseout="this.style.borderColor='rgba(255,255,255,0.04)'; this.style.transform='translateX(0)';">
                  <span style="white-space: normal; line-height: 1.3; word-break: break-word; flex: 1; min-width: 0; padding-right: 4px;">${l.title}</span>
                  <span style="color: var(--accent-cyan); font-size: 0.68rem; font-weight: 700; flex-shrink: 0; background: rgba(6, 182, 212, 0.1); padding: 3px 8px; border-radius: 4px; border: 1px solid rgba(6, 182, 212, 0.15); letter-spacing: 0.3px;">VISITAR ↗</span>
                </a>
              `).join('')}
            </div>
          </div>
        `;
      }

      // Sección de Datos Clave e Infografía (interestingData)
      if (Array.isArray(art.interestingData) && art.interestingData.length > 0) {
        html += `
          <div style="margin-top: 24px; margin-bottom: 16px;">
            <h4 style="font-family: var(--font-title); font-size: 0.82rem; color: var(--accent-purple); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
              <span>📊</span> Datos Clave de Interés
            </h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px;">
              ${art.interestingData.map(d => `
                <div style="padding: 10px 12px; background: rgba(255, 255, 255, 0.01); border: 1px solid var(--border-color); border-radius: 10px; display: flex; flex-direction: column; gap: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); min-width: 0; overflow: hidden;">
                  <span style="font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); font-weight: 600; white-space: normal; line-height: 1.2; word-break: break-word;">${d.label}</span>
                  <span style="font-size: 0.95rem; font-weight: 700; background: linear-gradient(90deg, #c084fc, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; white-space: normal; line-height: 1.25; word-break: break-word;" title="${d.value}">${d.value}</span>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }
      
      return html;
    }


    // Función para renderizar un artículo individual en la pila infinita
    function renderArticleItemHtml(art) {
      const categoryKey = (art.category || 'general').toLowerCase();
      const themeName = THEME_NAMES[categoryKey] || 'General';
      const imgUrl = getArticleImageUrl(art);
      
      // Metadata de tiempo
      const diffMs = Date.now() - new Date(art.publishedAt).getTime();
      const diffMin = Math.round(diffMs / 60000);
      const diffHours = Math.round(diffMs / 3600000);
      
      let breakingBadge = '';
      if (diffMs < 1 * 3600 * 1000) {
        const mins = diffMin <= 0 ? 1 : diffMin;
        breakingBadge = `<span class="card-breaking-badge card-lasthour-badge"><span class="pulsing-dot pulsing-dot-fast"></span>HACE ${mins}m</span>`;
      } else if (diffMs < 4 * 3600 * 1000) {
        breakingBadge = `<span class="card-breaking-badge"><span class="pulsing-dot"></span>HACE ${diffHours}h</span>`;
      }
      
      const dateStr = formatRelativeDate(art.publishedAt);
      const scrapedStr = art.scrapedAt ? `Analizado por IA: ${formatRelativeDate(art.scrapedAt)}` : 'Analizado recientemente por AIDAILY';
      
      // Puntos Clave
      let keyPointsHtml = '';
      if (Array.isArray(art.keyPoints) && art.keyPoints.length > 0) {
        keyPointsHtml = art.keyPoints.map(kp => `
          <div class="key-point-item">
            <span class="key-point-icon">•</span>
            <span>${kp}</span>
          </div>
        `).join('');
      } else {
        keyPointsHtml = `
          <div class="key-point-item">
            <span class="key-point-icon">•</span>
            <span>${art.title}</span>
          </div>`;
      }
      
      // Hashtags
      const subNormalized = getNormalizedSubcatPath(categoryKey, art.subcategory);
      const subReadable = art.subcategory ? getReadableSubcatForCard(categoryKey, art.subcategory) : '';
      const subHtml = subReadable ? ` &gt; <span onclick="event.stopPropagation(); selectSubcategory('${subNormalized}', '${categoryKey}'); closeArticleView();" style="cursor: pointer; transition: color 0.2s; text-decoration: underline;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--accent-cyan)'">${subReadable.toUpperCase()}</span>` : '';
      
      let hashtagsHtml = '';
      const cleanTags = getCleanHashtags(art.hashtags);
      if (cleanTags.length > 0) {
        hashtagsHtml = cleanTags.map(h => `
          <span class="card-tag clickable-tag" style="color: var(--accent-cyan); font-weight:600; cursor:pointer;" onclick="selectHashtagFromArticle('${h}')">${h}</span>
        `).join('');
      }

      const fullArticleHtml = renderArticleBodyHtml(art);

      return `
        <div class="article-item-wrapper" 
             style="border-bottom: 2px solid var(--border-color); padding-bottom: 60px; margin-bottom: 60px; animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);"
             data-article-id="${art.id}" 
             data-category="${art.category}" 
             data-subcategory="${art.subcategory || ''}" 
             data-title="${escapeHtmlAttr(art.title)}" 
             data-published="${art.publishedAt}">
           
                     <div class="article-detail-body">
            <img class="detail-hero-img" src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}">
            
            <div class="detail-meta">
              <span class="card-source clickable-source" style="cursor: pointer; text-decoration: underline;" onclick="selectSource('${escapeHtmlAttr(art.source)}'); closeArticleView();">${art.source.toUpperCase()}</span>${breakingBadge}
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 3px; font-size: 0.72rem; color: var(--text-muted); border-left: 2px solid var(--accent-cyan); padding-left: 8px; margin-bottom: 24px; line-height: 1.3;">
              <span>Publicación Original: ${dateStr}</span>
              <span>${scrapedStr}</span>
            </div>
            
            <h1 class="detail-title">${art.title}</h1>
            
            <!-- Puntos Clave -->
            <div class="detail-section">
              <h4 style="font-family: var(--font-title); font-size: 0.95rem; margin-bottom: 8px; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.5px;">Puntos Clave</h4>
              <div class="key-points-list">${keyPointsHtml}</div>
            </div>

            <!-- Por qué importa -->
            <div class="why-matters-box" style="margin-bottom: 24px;">
              <h4 style="font-family: var(--font-title); font-size: 0.85rem; margin-bottom: 4px; color: var(--accent-purple); text-transform: uppercase; letter-spacing: 0.5px;">Por qué importa</h4>
              <p>${art.whyMatters || 'Noticia relevante para el sector.'}</p>
            </div>

            <!-- Artículo Completo Redactado por IA -->
            <div class="detail-section">
              <h4 style="font-family: var(--font-title); font-size: 0.95rem; margin-bottom: 8px; color: var(--text-title); text-transform: uppercase; letter-spacing: 0.5px;">Artículo Completo</h4>
              <div class="detail-article-text">${fullArticleHtml}</div>
            </div>

            <!-- Tags/Hashtags -->
            <div class="card-tags" style="margin-top: 24px; border-top: 1px dashed var(--border-color); padding-top: 16px;">
              ${hashtagsHtml}
            </div>
          </div>

          <!-- Enlace Original -->
          <a class="cta-btn" href="${art.url}" target="_blank" style="margin-top: 20px; display: inline-flex; margin-bottom: 24px;">
            <span>Leer artículo original</span>
            <span>↗</span>
          </a>
        </div>
      `;
    }

    // Scroll Infinito del feed de inicio
    let feedIntersectionObserver = null;
    function setupFeedInfiniteScroll() {
      const sentinel = document.getElementById('feed-infinite-sentinel');
      const loadMoreBtn = document.getElementById('load-more-btn');
      if (!sentinel || !loadMoreBtn) return;

      if (feedIntersectionObserver) {
        feedIntersectionObserver.disconnect();
      }

      feedIntersectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !loadMoreBtn.disabled) {
            const loadMoreWrapper = document.getElementById('load-more-wrapper');
            // Si el wrapper de cargar más está configurado como block, significa que quedan artículos por cargar
            if (loadMoreWrapper && loadMoreWrapper.style.display !== 'none') {
              loadMoreBtn.click();
            }
          }
        });
      }, {
        rootMargin: "250px"
      });

      feedIntersectionObserver.observe(sentinel);
    }

    // Inicializar IntersectionObserver para rastrear qué artículo está visible
    function setupInfiniteScrollObserver() {
      if (infiniteIntersectionObserver) {
        infiniteIntersectionObserver.disconnect();
      }

      infiniteIntersectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const wrapper = entry.target;
            const title = wrapper.getAttribute('data-title');
            const published = wrapper.getAttribute('data-published');
            const category = wrapper.getAttribute('data-category');
            const subcategory = wrapper.getAttribute('data-subcategory');
            
            // Actualizar breadcrumb sticky scrolled
            const breadcrumbTitle = document.getElementById('breadcrumb-article-title');
            if (breadcrumbTitle) breadcrumbTitle.innerText = title;
            const breadcrumbDate = document.getElementById('breadcrumb-article-date');
            if (breadcrumbDate && published) breadcrumbDate.innerText = formatRelativeDate(published);
            
            // Actualizar el breadcrumb estático visible arriba
            const categoryKey = (category || 'general').toLowerCase();
            const themeName = THEME_NAMES[categoryKey] || 'General';
            const subNormalized = getNormalizedSubcatPath(categoryKey, subcategory);
            const subReadable = getReadableSubcatForCard(categoryKey, subcategory);
            const subHtml = subcategory ? ` &gt; <span onclick="event.stopPropagation(); selectSubcategory('${subNormalized}', '${categoryKey}'); closeArticleView();" style="cursor: pointer; transition: color 0.2s; text-decoration: underline;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--accent-cyan)'">${subReadable.toUpperCase()}</span>` : '';
            
            detailBreadcrumb.innerHTML = `
              <span onclick="event.stopPropagation(); goToHome()" style="cursor: pointer; transition: color 0.2s; text-decoration: underline;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--accent-cyan)'">INICIO</span> 
              &gt; 
              <span onclick="event.stopPropagation(); selectCategory('${categoryKey}'); closeArticleView();" style="cursor: pointer; transition: color 0.2s; text-decoration: underline;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--accent-cyan)'">${themeName.toUpperCase()}</span>
              ${subHtml}
            `;

            // Cambiar título del documento
            document.title = `${title} — AIDAILY`;
          }
        });
      }, {
        rootMargin: "-25% 0px -55% 0px" // Dispara cuando el artículo ocupa la zona superior de lectura
      });

      // Registrar todos los artículos inyectados actualmente
      document.querySelectorAll('.article-item-wrapper').forEach(el => {
        infiniteIntersectionObserver.observe(el);
      });
    }

    // Control de carga de artículos relacionados vía scroll
    let isLoadingNextArticle = false;
    let detailTriggerObserver = null;

    // Cargar siguiente bloque de artículos relacionados (Lotes de 6 en 6 v2.1)
    window.loadNextInfiniteArticleBatch = function() {
      if (isLoadingNextArticle) return;
      if (infiniteNextIndex >= infiniteArticlesQueue.length) {
        renderAlternativeTopicsProposal();
        return;
      }

      isLoadingNextArticle = true;

      // Mostrar feedback visual de carga en el botón
      const triggerBtn = document.getElementById('load-more-related-btn');
      if (triggerBtn) {
        triggerBtn.disabled = true;
        triggerBtn.innerHTML = `<span>Cargando artículos relacionados...</span><div class="spinner" style="width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.1); border-top-color: #fff; border-radius: 50%; display: inline-block; animation: spin 0.6s linear infinite; margin-left: 6px;"></div>`;
      }

      // Pequeño retardo de 400ms para experiencia premium
      setTimeout(() => {
        const container = document.getElementById('infinite-articles-container');
        if (container) {
          const batchSize = 6;
          const targetIndex = Math.min(infiniteNextIndex + batchSize, infiniteArticlesQueue.length);
          
          for (let i = infiniteNextIndex; i < targetIndex; i++) {
            const nextArt = infiniteArticlesQueue[i];
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = renderArticleItemHtml(nextArt);
            const articleNode = tempDiv.firstElementChild;
            container.appendChild(articleNode);
          }

          infiniteNextIndex = targetIndex;

          // Re-configurar observador de visibilidad (para breadcrumbs)
          setupInfiniteScrollObserver();

          // Actualizar el botón cargador
          renderInfiniteLoadingTrigger();
        }

        isLoadingNextArticle = false;
      }, 400);
    };

    // Renderizar botón de carga de relacionados v2.1
    function renderInfiniteLoadingTrigger() {
      const wrapper = document.getElementById('infinite-loading-trigger-wrapper');
      if (!wrapper) return;

      if (infiniteNextIndex < infiniteArticlesQueue.length) {
        wrapper.innerHTML = `
          <div class="load-more-related-container" style="text-align: center; padding: 30px 10px; margin-bottom: 50px;">
            <button id="load-more-related-btn" class="load-more-pill-btn" onclick="loadNextInfiniteArticleBatch()" style="display: inline-flex; align-items: center; gap: 8px;">
              <span>Cargar más artículos relacionados</span>
              <span>▼</span>
