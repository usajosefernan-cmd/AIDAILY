    function syncStateFromURL() {
      if (typeof window !== 'undefined' && window.dateParam) {
        activeCategory = 'date';
        activeDateParam = window.dateParam;
        const params = new URLSearchParams(window.location.search);
        currentPage = parseInt(params.get('p')) || 1;
        return;
      }

      const path = window.location.pathname.toLowerCase();
      const basePath = getBasePath().toLowerCase();
      
      let relativePath = path;
      if (path.startsWith(basePath)) {
        relativePath = path.substring(basePath.length);
      }
      relativePath = relativePath.replace(/^\/+|\/+$/g, '');
      
      const pathParts = relativePath.split('/');
      const cat = pathParts[0] || 'breaking';
      
      const pathCategories = [
        'actualidad', 'tecnologia-ciencia', 'economia-negocios', 'estilo-vida', 'deportes',
        'nacional', 'internacional', 'economia', 'tecnologia', 'ciencia', 'medioambiente', 'cultura', 'estilo', 'sociedad', 'opinion', 'gastronomia'
      ];
      if (pathCategories.includes(cat)) {
        activeCategory = cat;
      } else {
        activeCategory = 'breaking';
      }
      
      const params = new URLSearchParams(window.location.search);
      activeSubcategory = params.get('sub') || null;
      activeHashtag = params.get('tag') || null;
      activeSource = params.get('source') || null;
      searchQuery = params.get('q') || '';
      currentPage = parseInt(params.get('p')) || 1;
      
