    window.toggleMobilePortal = function(event, portal) {
      if (event) event.stopPropagation();
      const subList = document.getElementById(`drawer-portal-sub-${portal}`);
      if (subList) {
        const arrow = subList.previousElementSibling ? subList.previousElementSibling.querySelector('.drawer-arrow') : null;
        const isCurrentlyActive = subList.classList.contains('active');
        if (isCurrentlyActive) {
          subList.classList.remove('active');
          if (arrow) arrow.classList.remove('expanded');
        } else {
          subList.classList.add('active');
          if (arrow) arrow.classList.add('expanded');
        }
      }
    };

