    // Sanitización robusta de hashtags
    function getCleanHashtags(tags) {
      if (!Array.isArray(tags)) return [];
      const clean = [];
      const seen = new Set();
      
      tags.forEach(tag => {
        if (typeof tag !== 'string') return;
        
        // Quitar caracteres corruptos de control o símbolos raros y exclamaciones/puntuaciones finales
        let cleaned = tag.trim()
          .replace(/[,.!?;:\"']/g, '') // Quitar puntuación
          .replace(/[\#]/g, '')        // Quitar almohadillas repetidas
          .replace(/[^\w\d_áéíóúÁÉÍÓÚñÑüÜí-]/g, '') // Solo letras, números, guiones y caracteres españoles
          .trim();
        
        if (cleaned.length >= 2) {
          cleaned = '#' + cleaned.charAt(0).toUpperCase() + cleaned.slice(1);
          const lower = cleaned.toLowerCase();
          // Excluir hashtags genéricos o de fallback redundantes
          if (lower === '#noticias' || lower === '#noticia' || lower === '#actualidad') {
            return;
          }
          if (!seen.has(lower)) {
            seen.add(lower);
            clean.push(cleaned);
          }
        }
      });
      
      return clean;
    }

