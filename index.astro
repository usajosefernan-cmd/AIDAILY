    function renderContextualNav(overrideCategory, overrideSubcategory) {
      const subnavWrapper = document.getElementById('subcategories-wrapper');
      const subnavContainer = document.getElementById('subcategories-container');
      
      const currentCategory = overrideCategory || activeCategory;
      const currentSubcategory = (typeof overrideSubcategory !== 'undefined') ? overrideSubcategory : activeSubcategory;
      
      // Ocultar subnavegación si estamos en portada sin filtros y no hay override
      if (currentCategory === 'breaking' && !searchQuery && !activeHashtag && currentCategory !== 'date' && !overrideCategory) {
        if (subnavWrapper) subnavWrapper.style.display = 'none';
        return;
      }
      if (!categoriesContainer) return;

      // A) Caso de Búsqueda Activa
      if (searchQuery) {
        let breadcrumbHtml = `<div class="subnav-breadcrumbs">`;
        breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="goToHome()">Inicio</a>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active">Búsqueda</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active" style="text-transform: none;">"${searchQuery}"</span>`;
        breadcrumbHtml += `</div>`;

        const portalKeys = ['actualidad', 'tecnologia-ciencia', 'economia-negocios', 'estilo-vida', 'deportes'];
        let rightChipsHtml = portalKeys.map(portal => {
          const name = PORTAL_NAMES[portal] || portal;
          return `
            <a class="subnav-mini-link" onclick="selectCategory('${portal}')">
              ${name}
            </a>
          `;
        }).join('');

        const separatorHtml = `<span class="subnav-section-divider">|</span>`;
        const rightContainerHtml = `<div class="subnav-mini-verticals">${rightChipsHtml}</div>`;
        if (subnavContainer && subnavWrapper) {
          subnavContainer.innerHTML = breadcrumbHtml + separatorHtml + rightContainerHtml;
          subnavWrapper.style.display = 'block';
        }
        return;
      }

      // B) Caso de Hashtag Activo
      if (activeHashtag) {
        let breadcrumbHtml = `<div class="subnav-breadcrumbs">`;
        breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="goToHome()">Inicio</a>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="goToHome()">Tendencias</a>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active">${activeHashtag}</span>`;
        breadcrumbHtml += `</div>`;

        const hashtagsMap = {};
        allArticles.forEach(art => {
          const clean = getCleanHashtags(art.hashtags);
          clean.forEach(t => { hashtagsMap[t] = (hashtagsMap[t] || 0) + 1; });
        });
        const topTags = Object.entries(hashtagsMap)
          .sort((a, b) => b[1] - a[1])
          .slice(0, 6)
          .map(([t]) => t);

        let rightChipsHtml = ``;
        topTags.forEach(t => {
          const isActive = (t === activeHashtag);
          rightChipsHtml += `
            <a class="subnav-mini-link ${isActive ? 'active' : ''}" onclick="selectHashtagFromCard('${t}')">
              ${t}
            </a>
          `;
        });

        const separatorHtml = `<span class="subnav-section-divider">|</span>`;
        const rightContainerHtml = `<div class="subnav-mini-verticals">${rightChipsHtml}</div>`;
        if (subnavContainer && subnavWrapper) {
          subnavContainer.innerHTML = breadcrumbHtml + separatorHtml + rightContainerHtml;
          subnavWrapper.style.display = 'block';
        }
        return;
      }

      // C) Caso de Vista de Fecha Activa (Archivo)
      if (currentCategory === 'date' && activeDateParam) {
        let breadcrumbHtml = `<div class="subnav-breadcrumbs">`;
        breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="goToHome()">Inicio</a>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active">Archivo</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active">${activeDateParam}</span>`;
        breadcrumbHtml += `</div>`;

        const dateChips = [];
        for (let i = 0; i < 7; i++) {
          const d = new Date();
          d.setDate(d.getDate() - i);
          const dateStr = d.toISOString().split('T')[0];
          dateChips.push(dateStr);
        }

        let rightChipsHtml = dateChips.map(dateStr => {
          const isActive = (dateStr === activeDateParam);
          const label = dateStr.substring(5); // MM-DD
          return `
            <a class="subnav-mini-link ${isActive ? 'active' : ''}" href="/${dateStr}/">
              ${label}
            </a>
          `;
        }).join('');

        const separatorHtml = `<span class="subnav-section-divider">|</span>`;
        const rightContainerHtml = `<div class="subnav-mini-verticals">${rightChipsHtml}</div>`;
        if (subnavContainer && subnavWrapper) {
          subnavContainer.innerHTML = breadcrumbHtml + separatorHtml + rightContainerHtml;
          subnavWrapper.style.display = 'block';
        }
        return;
      }

      let activePortal = null;
      if (PORTAL_MAPPING[currentCategory]) {
        activePortal = activeCategory;
      } else {
        for (const [portal, categories] of Object.entries(PORTAL_MAPPING)) {
          if (categories.includes(currentCategory)) {
            activePortal = portal;
            break;
          }
        }
      }

      if (!activePortal || activePortal === 'breaking') {
        return;
      }

      // 1. CONSTRUCCIÓN DE BREADCRUMBS (LADO IZQUIERDO)
      let breadcrumbHtml = `<div class="subnav-breadcrumbs">`;
      // Nivel 1: Inicio
      breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="goToHome()">Inicio</a>`;

      const getBreadcrumbName = (key) => {
        return BREADCRUMB_NAMES[key] || THEME_NAMES[key] || PORTAL_NAMES[key] || (key.charAt(0).toUpperCase() + key.slice(1));
      };

      const portalNameCompact = getBreadcrumbName(activePortal);
      const catNameCompact = getBreadcrumbName(currentCategory);

      // Determinar si el portal y la categoría de nivel 3 son redundantes
      const isRedundant = (activePortal === currentCategory) || 
                          (activePortal === 'tecnologia-ciencia' && currentCategory === 'tecnologia') ||
                          (activePortal === 'economia-negocios' && currentCategory === 'economia') ||
                          (activePortal === 'estilo-vida' && currentCategory === 'estilo');

      if (currentCategory === activePortal) {
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        breadcrumbHtml += `<span class="subnav-breadcrumb-link active">${portalNameCompact}</span>`;
      } else {
        if (!isRedundant) {
          breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
          breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="selectCategory('${activePortal}')">${portalNameCompact}</a>`;
        }
        
        const isCatActive = !currentSubcategory;
        breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
        if (isCatActive) {
          breadcrumbHtml += `<span class="subnav-breadcrumb-link active">${catNameCompact}</span>`;
        } else {
          breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="selectCategory('${currentCategory}')">${catNameCompact}</a>`;
        }

        if (currentSubcategory) {
          const subcatParts = currentSubcategory.split('/');
          let currentPath = '';
          subcatParts.forEach((part, index) => {
            currentPath = currentPath ? `${currentPath}/${part}` : part;
            const isLast = (index === subcatParts.length - 1);
            const partReadable = SUBCATEGORY_NAMES[part] || getBreadcrumbName(part);
            
            breadcrumbHtml += `<span class="subnav-breadcrumb-separator">›</span>`;
            if (isLast) {
              breadcrumbHtml += `<span class="subnav-breadcrumb-link active">${partReadable}</span>`;
            } else {
              breadcrumbHtml += `<a class="subnav-breadcrumb-link" onclick="selectSubcategory('${currentPath}', '${currentCategory}')">${partReadable}</a>`;
            }
          });
        }
      }
      breadcrumbHtml += `</div>`;

      // 2. CONSTRUCCIÓN DE OPCIONES CONTEXTUALES / CHIPS (LADO DERECHO)
      let rightChipsHtml = ``;

      if (currentCategory === activePortal) {
        const portalCats = PORTAL_MAPPING[activePortal] || [];
        if (portalCats.length === 1) {
          const soleCat = portalCats[0];
          const subTree = CATEGORY_TREE[soleCat]?.children || {};
          if (Object.keys(subTree).length > 0) {
            rightChipsHtml += `
              <a class="subnav-mini-link active" onclick="selectCategory('${soleCat}')">
                Todo
              </a>
            `;
            Object.entries(subTree).forEach(([subKey, subNode]) => {
              rightChipsHtml += `
                <a class="subnav-mini-link" onclick="selectSubcategory('${subKey}', '${soleCat}', event)">
                  ${subNode.name}
                </a>
              `;
            });
            const separatorHtml = `<span class="subnav-section-divider">|</span>`;
            const rightContainerHtml = `<div class="subnav-mini-verticals">${rightChipsHtml}</div>`;
            if (subnavContainer && subnavWrapper) {
              subnavContainer.innerHTML = breadcrumbHtml + separatorHtml + rightContainerHtml;
              subnavWrapper.style.display = 'block';
            }
            return;
          }
        }
        
        rightChipsHtml += `
          <a class="subnav-mini-link active" onclick="selectCategory('${activePortal}')">
            Todo
          </a>
        `;
        portalCats.forEach(cat => {
          const catName = THEME_NAMES[cat] || cat;
          rightChipsHtml += `
            <a class="subnav-mini-link" onclick="selectCategory('${cat}')">
              ${catName}
            </a>
          `;
        });
      } else if (!currentSubcategory) {
        rightChipsHtml += `
          <a class="subnav-mini-link active" onclick="selectCategory('${currentCategory}')">
            Todo
          </a>
        `;
        const subTree = CATEGORY_TREE[currentCategory]?.children || {};
        Object.entries(subTree).forEach(([subKey, subNode]) => {
          rightChipsHtml += `
            <a class="subnav-mini-link" onclick="selectSubcategory('${subKey}', '${currentCategory}', event)">
              ${subNode.name}
            </a>
          `;
        });
      } else {
        const subParts = currentSubcategory.split('/');
        const subcatRoot = subParts[0];
        const catNode = CATEGORY_TREE[currentCategory];
        let subSubNode = null;
        let hasSubChildren = false;

        if (catNode && catNode.children && catNode.children[subcatRoot]) {
          subSubNode = catNode.children[subcatRoot];
          if (subSubNode && subSubNode.children && Object.keys(subSubNode.children).length > 0) {
            hasSubChildren = true;
          }
        }

        if (hasSubChildren) {
          const isRootActive = (currentSubcategory === subcatRoot);
          rightChipsHtml += `
            <a class="subnav-mini-link ${isRootActive ? 'active' : ''}" onclick="selectSubcategory('${subcatRoot}', '${currentCategory}', event)">
              Todo
            </a>
          `;
          Object.entries(subSubNode.children).forEach(([subSubKey, subSubNodeItem]) => {
            const fullPath = `${subcatRoot}/${subSubKey}`;
            const isSubSubActive = (currentSubcategory === fullPath);
            rightChipsHtml += `
              <a class="subnav-mini-link ${isSubSubActive ? 'active' : ''}" onclick="selectSubcategory('${fullPath}', '${currentCategory}', event)">
                ${subSubNodeItem.name}
              </a>
            `;
          });
        } else {
          rightChipsHtml += `
            <a class="subnav-mini-link" onclick="selectCategory('${currentCategory}')">
              Todo
            </a>
          `;
          const siblings = catNode?.children || {};
          Object.entries(siblings).forEach(([subKey, subNode]) => {
            const isSubActive = (currentSubcategory === subKey);
            rightChipsHtml += `
              <a class="subnav-mini-link ${isSubActive ? 'active' : ''}" onclick="selectSubcategory('${subKey}', '${currentCategory}', event)">
                ${subNode.name}
              </a>
            `;
          });
        }
      }

      const separatorHtml = `<span class="subnav-section-divider">|</span>`;
      const rightContainerHtml = `<div class="subnav-mini-verticals">${rightChipsHtml}</div>`;
      
      if (subnavContainer && subnavWrapper) {
        subnavContainer.innerHTML = breadcrumbHtml + separatorHtml + rightContainerHtml;
        subnavWrapper.style.display = 'block';
      }
    }

    // Renderizar categorías principales con submenús desplegables en cascada y mega-dropdowns tipo NYT
    function renderCategories() {
      if (!categoriesContainer) return;

      // Helper para obtener temas calientes en vivo de un portal
      function getLiveThemesForPortal(portal) {
        const portalCats = PORTAL_MAPPING[portal] || [portal];
        const topics = Object.values(window.trendingTopics || {})
          .filter(t => t && t.id && t.id !== 'updatedAt' && t.id !== 'windowHours');
        
        return topics.filter(t => {
          const cat = t.category ? t.category.toLowerCase().trim() : '';
          return portalCats.includes(cat) || portalCats.some(c => c === cat);
        });
      }

      // Renderizar siempre la barra principal de portales con sus megamenús
      const portalKeys = ['breaking', 'actualidad', 'tecnologia-ciencia', 'economia-negocios', 'estilo-vida', 'deportes'];

      let html = portalKeys.map(portal => {
        const name = THEME_NAMES[portal] || portal;
        const isActive = activeCategory === portal || (PORTAL_MAPPING[portal] && PORTAL_MAPPING[portal].includes(activeCategory));

        if (portal === 'breaking') {
          return `
            <div class="category-dropdown-wrapper">
              <a class="category-link ${isActive ? 'active' : ''}" onclick="selectCategory('breaking')" style="color: #f87171; font-weight: 700; display: inline-flex; align-items: center; gap: 4px;">
                <span class="pulsing-dot"></span> ${name}
              </a>
            </div>
          `;
        }

        // Obtener la descripción explicativa del portal
        const descriptionText = PORTAL_DESCRIPTIONS[portal] || '';
        const descriptionHtml = descriptionText ? `<div class="mega-menu-description"><strong>${name}</strong>: ${descriptionText}</div>` : '';

        // Obtener artículos recomendados del portal completo
        const portalCats = PORTAL_MAPPING[portal] || [];
        const featuredArts = allArticles
          .filter(art => portalCats.includes(normalizeText(art.category)))
          .sort((a, b) => {
            const aHasImg = (a.imageUrl && !a.imageUrl.includes('placeholder') && !a.imageUrl.startsWith('http://localhost')) ? 1 : 0;
            const bHasImg = (b.imageUrl && !b.imageUrl.includes('placeholder') && !b.imageUrl.startsWith('http://localhost')) ? 1 : 0;
            if (aHasImg !== bHasImg) return bHasImg - aHasImg;
            return getSafeTime(b) - getSafeTime(a);
          })
          .slice(0, 3);
        
        let featuredHtml = '';
        if (featuredArts.length > 0) {
          const itemsHtml = featuredArts.map(art => {
            const imgUrl = getArticleImageUrl(art);
            return `
              <div class="mega-featured-item" onclick="openArticle('${art.id}')">
                <img src="${imgUrl}" alt="${escapeHtmlAttr(art.title)}" loading="lazy">
                <div class="mega-featured-item-text">
                  <h5>${art.title}</h5>
                  <p>${art.summary}</p>
                </div>
              </div>
            `;
          }).join('');
          
          featuredHtml = `
            <div class="mega-menu-featured">
              <h4>Lo Último</h4>
              ${itemsHtml}
            </div>
          `;
        } else {
          featuredHtml = `
            <div class="mega-menu-featured">
              <h4>Lo Último</h4>
              <div style="font-size: 0.7rem; color: var(--text-muted); padding: 4px 0;">No hay reportes recientes en este portal.</div>
            </div>
          `;
        }

        // Columna de temas calientes "En Vivo" del portal
        const liveThemes = getLiveThemesForPortal(portal);
        const liveColHtml = liveThemes.length > 0 ? `
          <div class="mega-menu-col" style="border-right: 1px solid rgba(239, 68, 68, 0.15); padding-right: 16px; margin-right: 12px; min-width: 140px;">
            <h4 style="color: #ef4444; display: flex; align-items: center; gap: 6px; font-weight: 800;">
              <span class="pulsing-dot pulsing-dot-fast" style="width: 6px; height: 6px; background-color: #ef4444; border-radius: 50%; box-shadow: 0 0 8px #ef4444; display: inline-block;"></span> EN VIVO
            </h4>
            <div class="mega-sub-links" style="display: flex; flex-direction: column; gap: 4px;">
              ${liveThemes.map(t => {
                const isTActive = window.activeTrendingTopic && window.activeTrendingTopic.id === t.id;
                return `
                  <a class="mega-menu-link live-theme-item ${isTActive ? 'active' : ''}" onclick="selectTrendingTopic('${t.id}')" style="color: #f87171; font-weight: 700; font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; border: 1px solid ${isTActive ? 'rgba(239,68,68,0.2)' : 'rgba(255,255,255,0.03)'}; background: ${isTActive ? 'rgba(239,68,68,0.1)' : 'rgba(255,255,255,0.01)'}; line-height: 1.25;">
                    ${t.title}
                  </a>
                `;
              }).join('')}
            </div>
          </div>
        ` : '';

        // Dividir subcategorías en columnas
        let columnsHtml = '';
        if (portal === 'economia-negocios') {
          columnsHtml = `
            ${liveColHtml}
            <div class="mega-menu-col">
              <h4 onclick="selectCategory('economia', event)" style="cursor: pointer;" onmouseover="this.style.color='var(--accent-cyan)'" onmouseout="this.style.color='var(--text-title)'">MERCADOS BURSÁTILES</h4>
              <div class="mega-sub-links">
                <a class="mega-menu-link ${activeCategory === 'economia' && activeSubcategory === 'mercados' ? 'active' : ''}" onclick="selectSubcategory('mercados', 'economia', event)">Bolsas & Divisas</a>
              </div>
            </div>
            <div class="mega-menu-col">
              <h4 onclick="selectCategory('economia', event)" style="cursor: pointer;" onmouseover="this.style.color='var(--accent-cyan)'" onmouseout="this.style.color='var(--text-title)'">FINANZAS PERSONALES</h4>
              <div class="mega-sub-links">
                <a class="mega-menu-link ${activeCategory === 'economia' && activeSubcategory === 'finanzas' ? 'active' : ''}" onclick="selectSubcategory('finanzas', 'economia', event)">Ahorro & Inversión</a>
              </div>
            </div>
            <div class="mega-menu-col">
