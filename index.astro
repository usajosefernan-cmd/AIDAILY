    // Función de similitud léxica Jaccard para titulares en el cliente
    function calculateJaccardSimilarityForTitles(t1, t2) {
      const stopwords = new Set([
        'para', 'como', 'sino', 'pero', 'este', 'esta', 'estos', 'estas', 'todo', 'toda', 'todos', 'todas',
        'unos', 'unas', 'sobre', 'entre', 'desde', 'hasta', 'hacia', 'porque', 'cuando', 'donde', 'quien',
        'cual', 'cuyo', 'cuya', 'cuyos', 'cuyas', 'contra', 'durante', 'frente', 'sobre', 'tienen', 'noticias',
        'noticia', 'articulo', 'articulos', 'prensa', 'diario', 'mundo', 'pais', 'espana', 'nuevo', 'nueva',
        'con', 'del', 'los', 'las', 'una', 'uno', 'por', 'sus', 'que', 'les'
      ]);
      
      const clean = (text) => {
        if (!text) return new Set();
        const words = text.toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/[^\w\s]/g, " ")
          .split(/\s+/)
          .filter(w => w.length > 3 && !stopwords.has(w));
        return new Set(words);
      };

      const s1 = clean(t1);
      const s2 = clean(t2);
      if (s1.size === 0 || s2.size === 0) return 0;

      let intersection = 0;
      s1.forEach(w => {
        if (s2.has(w)) intersection++;
      });
      const union = s1.size + s2.size - intersection;
      return intersection / union;
    }

